# ── Database (Supabase Postgres — session pooler, IPv4-friendly) ────
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ── Storage / logs ─────────────────────────────────────────────────
STORAGE_DIR=./storage
LOG_LEVEL=INFO

# Public site (canonical domain for SEO, emails, links)
SITE_URL=https://REPLACE_ME_DOMAIN.com

# ── OpenAI (REQUIRED — powers LLM content generation) ─────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
LLM_CALL_BUDGET_PER_RUN=200

# Premium model — used for evergreen, high-traffic landing pages only
OPENAI_PREMIUM_MODEL=gpt-5.2
LLM_PREMIUM_INPUT_PRICE_PER_MTOK=5.00
LLM_PREMIUM_OUTPUT_PRICE_PER_MTOK=15.00

# ── Newsletter (Buttondown subscriber signup) ──
NEWSLETTER_PROVIDER=buttondown
BUTTONDOWN_API_KEY=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── Payments (Stripe consultation bookings) ──
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONSULTATION_PAYMENT_LINK_ID=
ORDER_NOTIFICATION_EMAIL=you@example.com
ORDER_EMAIL_PROVIDER=resend
ORDER_FROM_EMAIL=

# ── Admin ──
ADMIN_KEY=change-me-to-a-random-string
ADMIN_PASSWORD=change-me

# ── Google Analytics (GA4) ──
# Replace with your GA4 measurement ID (e.g. G-XXXXXXXXXX)
GOOGLE_ANALYTICS_ID=

# ── Google Reporting (GA4 + Search Console) ──
GOOGLE_REPORTING_SA_JSON=
GOOGLE_REPORTING_SA_FILE=
GOOGLE_REPORTING_GA4_PROPERTY_ID=
GOOGLE_REPORTING_GSC_SITE_URL=

# ── SEO: Semrush ──
SEMRUSH_API_KEY=
SEMRUSH_DATABASE=us

# ── Backlink Outreach ──
RESEND_OUTREACH_FROM=
OUTREACH_MIN_SCORE=65
OUTREACH_BATCH_SIZE=50

# ── Supabase Storage ─────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_REPORT_BUCKET=reports

# ── Distribution: IndexNow ──
INDEXNOW_KEY=

# ── Distribution: Google Indexing API ──
GOOGLE_INDEXING_SA_JSON=
GOOGLE_INDEXING_SA_FILE=

# ── Distribution: Internet Archive ──
INTERNET_ARCHIVE_ACCESS_KEY=
INTERNET_ARCHIVE_SECRET_KEY=
INTERNET_ARCHIVE_COLLECTION=opensource

# ── Distribution: Zenodo ──
ZENODO_ACCESS_TOKEN=
ZENODO_USE_SANDBOX=
ZENODO_COMMUNITY=

# ── Distribution: OSF Preprints ──
OSF_ACCESS_TOKEN=
OSF_PROJECT_NODE_ID=
OSF_PREPRINT_PROVIDER=osf

# ── Distribution: Bluesky ──
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── Sitemap Sync (nightly cron) ──
# Fine-grained GitHub PAT with Contents: Read & Write on the repo.
# Needed so the nightly cron can commit + push sitemap fixes.
# Without it, the script still audits and reports — just can't push.
GITHUB_TOKEN=
GITHUB_REPO=jht243/metabolic_health

# ── Server ──
SERVER_PORT=8080
