    This site provides health information for educational purposes only. It is not medical advice. Always consult a qualified healthcare provider.
  </span>
</footer>

<script>
(function initNavToggle() {
  var btn = document.querySelector('.top-nav .nav-toggle');
  var nav = document.querySelector('.top-nav');
  if (!btn || !nav) return;
  function setOpen(open) {
    nav.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }
  btn.addEventListener('click', function() {
    setOpen(!nav.classList.contains('is-open'));
  });
  nav.querySelectorAll('.nav-links a').forEach(function(a) {
    a.addEventListener('click', function() { setOpen(false); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') setOpen(false);
  });
})();

(function initShareButtons() {
  var toastEl = null;
  function showToast(msg) {
    if (!toastEl) {
      toastEl = document.createElement('div');
      toastEl.className = 'share-toast';
      document.body.appendChild(toastEl);
    }
    toastEl.textContent = msg;
    requestAnimationFrame(function() { toastEl.classList.add('is-visible'); });
    clearTimeout(toastEl._hideTimer);
    toastEl._hideTimer = setTimeout(function() {
      toastEl.classList.remove('is-visible');
    }, 1600);
  }
  function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    return new Promise(function(resolve, reject) {
      try {
        var ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.select(); document.execCommand('copy');
        document.body.removeChild(ta); resolve();
      } catch (err) { reject(err); }
    });
  }
  document.querySelectorAll('.share-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = btn.getAttribute('data-share-url') || window.location.href;
      var title = btn.getAttribute('data-share-title') || document.title;
      /* Decision: "Which content earns shares, and via which method?" */
      function trackShare(method){
        if(window._ga) window._ga('share_action',{method:method,page_path:location.pathname,content_title:title});
      }
      if (navigator.share) {
        navigator.share({ title: title, url: url }).then(function(){trackShare('share_api')}).catch(function() {
          copyToClipboard(url).then(function() { showToast('Link copied'); trackShare('clipboard'); });
        });
        return;
      }
      copyToClipboard(url).then(function() { showToast('Link copied'); trackShare('clipboard'); }).catch(function() { showToast('Could not copy link'); });
    });
  });
})();

(function initFeedbackWidget() {
  var desktopQuery = window.matchMedia ? window.matchMedia('(min-width: 769px)') : null;
  if (desktopQuery && !desktopQuery.matches) return;

  var widget = document.querySelector('[data-feedback-widget]');
  if (!widget) return;

  var openBtn = widget.querySelector('[data-feedback-open]');
  var closeBtn = widget.querySelector('[data-feedback-close]');
  var panel = widget.querySelector('#feedback-panel');
  var form = widget.querySelector('[data-feedback-form]');
  var textarea = form ? form.querySelector('textarea[name="feedback"]') : null;
  var submitBtn = form ? form.querySelector('[data-feedback-submit]') : null;
  var status = widget.querySelector('[data-feedback-status]');
  if (!openBtn || !closeBtn || !panel || !form || !textarea || !submitBtn || !status) return;

  function setStatus(message, kind) {
    status.textContent = message || '';
    status.classList.toggle('is-success', kind === 'success');
    status.classList.toggle('is-error', kind === 'error');
  }
  function setOpen(open) {
    widget.classList.toggle('is-open', open);
    panel.hidden = !open;
    openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) {
      setTimeout(function() { textarea.focus(); }, 40);
    } else {
      openBtn.focus();
    }
  }

  openBtn.addEventListener('click', function() {
    setOpen(!widget.classList.contains('is-open'));
  });
  closeBtn.addEventListener('click', function() {
    setOpen(false);
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && widget.classList.contains('is-open')) setOpen(false);
  });
  function submitFeedback() {
    var feedback = textarea.value.trim();
    if (!feedback) {
      setStatus('Please add a little feedback first.', 'error');
      textarea.focus();
      return;
    }
    if (feedback.length > 2000) {
      setStatus('Feedback must be 2000 characters or fewer.', 'error');
      textarea.focus();
      return;
    }

    submitBtn.disabled = true;
    setStatus('Sending...', '');
    fetch('/api/feedback', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ feedback: feedback, page_url: window.location.href })
    }).then(function(resp) {
      if (!resp.ok) throw new Error('feedback_failed');
      return resp.json();
    }).then(function() {
      textarea.value = '';
      setStatus('Thanks - your idea was sent.', 'success');
      if (window._ga) window._ga('form_submit', { form_name: 'feedback', page_path: location.pathname });
    }).catch(function() {
      setStatus('Could not send that yet. Please try again.', 'error');
    }).finally(function() {
      submitBtn.disabled = false;
    });
  }
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    submitFeedback();
  });
  submitBtn.addEventListener('click', function(e) {
    e.preventDefault();
    submitFeedback();
  });
})();
</script>
{% block scripts_extra %}{% endblock %}
{% include "_analytics_events.html.j2" %}
</body>
</html>
