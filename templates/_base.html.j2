{#
  Shared base layout for the health optimization site. Inherits the visual
  identity from the original project — Libre Baskerville + Open Sans + a
  clinical navy/teal palette — but rebranded for metabolic & hormonal health.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "_google_tag.html.j2" %}

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% set _seo = seo|default({}) %}
  {% set _site_name = site_name|default('The Metabolic Journal') %}
  {% set _site_url = site_url|default('https://themetabolicjournal.com') %}
  {% set _site_icon = _site_url ~ '/static/site-icon-512.png' %}
  <title>{{ _seo.title|default(_site_name) }}</title>
  <meta name="description" content="{{ _seo.description|default('') }}">
  {% if _seo.keywords %}<meta name="keywords" content="{{ _seo.keywords }}">{% endif %}
  <meta name="author" content="{{ _seo.site_name|default(_site_name) }}">
  <meta name="application-name" content="{{ _site_name }}">
  <meta name="apple-mobile-web-app-title" content="{{ _site_name }}">
  <meta name="theme-color" content="#0c1f3f">
  <meta name="robots" content="{{ _seo.robots|default('index, follow, max-image-preview:large, max-snippet:-1') }}">
  <link rel="canonical" href="{{ _seo.canonical|default('') }}">
  <link rel="alternate" hreflang="en" href="{{ _seo.canonical|default('') }}">
  <link rel="alternate" hreflang="x-default" href="{{ _seo.canonical|default('') }}">
  <link rel="icon" href="/static/favicon.ico" sizes="any">
  <link rel="icon" href="/static/site-icon.svg" type="image/svg+xml">
  <link rel="icon" href="/static/site-icon-48.png" type="image/png" sizes="48x48">
  <link rel="apple-touch-icon" href="/static/apple-touch-icon.png" sizes="180x180">
  <link rel="manifest" href="/static/site.webmanifest">

  <meta property="og:type" content="{{ _seo.og_type|default('website') }}">
  <meta property="og:site_name" content="{{ _seo.site_name|default(_site_name) }}">
  <meta property="og:locale" content="{{ _seo.locale|default('en_US') }}">
  <meta property="og:url" content="{{ _seo.canonical|default('') }}">
  <meta property="og:title" content="{{ _seo.title|default('') }}">
  <meta property="og:description" content="{{ _seo.description|default('') }}">
  <meta property="og:image" content="{{ _seo.og_image|default('') }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  {% if _seo.published_iso %}<meta property="article:published_time" content="{{ _seo.published_iso }}">{% endif %}
  {% if _seo.modified_iso %}<meta property="article:modified_time" content="{{ _seo.modified_iso }}">{% endif %}
  {% if _seo.section %}<meta property="article:section" content="{{ _seo.section }}">{% endif %}
  {% for tag in _seo.article_tags|default([]) %}<meta property="article:tag" content="{{ tag }}">
  {% endfor %}

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ _seo.title|default('') }}">
  <meta name="twitter:description" content="{{ _seo.description|default('') }}">
  <meta name="twitter:image" content="{{ _seo.og_image|default('') }}">

  <link rel="preload" href="/static/fonts/open-sans/OpenSans-Latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/static/fonts/libre-baskerville/LibreBaskerville-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <style>
    @font-face {
      font-family: 'Open Sans';
      font-style: normal;
      font-weight: 300 800;
      font-stretch: 100%;
      font-display: swap;
      src: url(/static/fonts/open-sans/OpenSans-Latin.woff2) format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Open Sans';
      font-style: italic;
      font-weight: 300 800;
      font-stretch: 100%;
      font-display: swap;
      src: url(/static/fonts/open-sans/OpenSans-Italic-Latin.woff2) format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Libre Baskerville';
      font-style: normal;
      font-weight: 400 700;
      font-display: swap;
      src: url(/static/fonts/libre-baskerville/LibreBaskerville-Regular.woff2) format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
      font-family: 'Libre Baskerville';
      font-style: italic;
      font-weight: 400;
      font-display: swap;
      src: url(/static/fonts/libre-baskerville/LibreBaskerville-Italic.woff2) format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
  </style>

  <script type="application/ld+json">{{ {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": _site_name,
    "alternateName": "Metabolic Journal",
    "url": _site_url
  } | tojson | safe }}</script>
  <script type="application/ld+json">{{ {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": _site_name,
    "url": _site_url,
    "logo": _site_icon
  } | tojson | safe }}</script>
  {% if jsonld %}
  <script type="application/ld+json">{{ jsonld | safe }}</script>
  {% endif %}

  <style>
    :root {
      --h-navy: #0c1f3f;
      --h-navy-dark: #071428;
      --h-teal: #0d9488;
      --h-teal-dark: #0a7d72;
      --h-accent: #f59e0b;
      --h-gray-bg: #f8fafb;
      --h-gray-light: #e5eaf0;
      --h-gray-text: #64748b;
      --h-dark-text: #1e293b;
      --white: #ffffff;
      --font-serif: 'Libre Baskerville', 'Times New Roman', Times, serif;
      --font-sans: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-sans); background: var(--white); color: var(--h-dark-text); line-height: 1.65; font-size: 17px; -webkit-font-smoothing: antialiased; }
    a { color: var(--h-teal-dark); text-decoration: underline; text-decoration-color: var(--h-gray-light); text-underline-offset: 3px; }
    a:hover { color: var(--h-teal); text-decoration-color: var(--h-teal); }

    /* ── Top Nav ── */
    .top-nav { background-color: var(--h-navy); color: var(--white); padding: 12px 0; font-family: var(--font-sans); }
    .top-nav-inner { max-width: 1140px; margin: 0 auto; padding: 0 20px; display: flex; justify-content: space-between; align-items: center; }
    .nav-brand { font-family: var(--font-serif); font-size: 1.25rem; font-weight: 700; letter-spacing: 0.3px; color: var(--white); text-decoration: none; display: flex; align-items: center; gap: 10px; line-height: 1; }
    .nav-brand .brand-icon { width: 30px; height: 30px; background: var(--white); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .nav-brand .brand-icon svg { width: 22px; height: 22px; display: block; }
    .nav-links { display: flex; align-items: center; gap: 22px; font-size: 0.82rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; line-height: 1; }
    .nav-links a { color: var(--white); text-decoration: none; transition: opacity 0.2s; display: inline-flex; align-items: center; }
    .nav-links a:hover { opacity: 0.8; }
    .nav-action { background: var(--h-teal); padding: 9px 18px; border-radius: 4px; line-height: 1; }
    .nav-action:hover { background: var(--h-teal-dark); opacity: 1; }

    .nav-toggle { display: none; background: transparent; border: 0; padding: 8px; margin: -8px -4px -8px 0; cursor: pointer; -webkit-tap-highlight-color: transparent; }
    .nav-toggle-bar { display: block; width: 24px; height: 2px; background: var(--white); border-radius: 2px; margin: 5px 0; transition: transform 0.2s ease, opacity 0.15s ease; }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) { opacity: 0; }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    @media (max-width: 768px) {
      .top-nav-inner { flex-wrap: wrap; }
      .nav-toggle { display: block; }
      .nav-links { display: none; flex-direction: column; align-items: stretch; width: 100%; gap: 0; margin-top: 12px; padding-top: 6px; border-top: 1px solid rgba(255,255,255,0.15); font-size: 0.95rem; }
      .nav-links a { padding: 14px 4px; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .nav-links a:last-child { border-bottom: 0; }
      .nav-action { display: inline-block; align-self: flex-start; margin-top: 10px; padding: 10px 18px; }
      .top-nav.is-open .nav-links { display: flex; }
    }

    /* ── Layout ── */
    .container { max-width: 760px; margin: 0 auto; padding: 0 24px; }
    .container-wide { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* ── Breadcrumbs ── */
    .breadcrumbs { font-size: 13px; color: var(--h-gray-text); margin: 24px 0 12px; display: flex; align-items: center; flex-wrap: wrap; gap: 6px; }
    .breadcrumbs a { color: var(--h-gray-text); }

    /* ── Article ── */
    article header h1 { font-family: var(--font-serif); font-size: 36px; line-height: 1.2; color: var(--h-navy); margin: 12px 0; font-weight: 700; }
    article header .subtitle { font-family: var(--font-serif); font-style: italic; font-size: 20px; color: var(--h-gray-text); margin-bottom: 18px; }
    article header .meta { font-size: 13px; color: var(--h-gray-text); border-top: 1px solid var(--h-gray-light); border-bottom: 1px solid var(--h-gray-light); padding: 12px 0; margin-bottom: 28px; display: flex; gap: 18px; flex-wrap: wrap; }
    article header .meta strong { color: var(--h-dark-text); }
    article .body h2 { font-family: var(--font-serif); font-size: 24px; color: var(--h-navy); margin: 32px 0 12px; font-weight: 700; }
    article .body h3 { font-family: var(--font-serif); font-size: 19px; color: var(--h-navy); margin: 24px 0 10px; }
    article .body p { margin: 0 0 16px; }
    article .body ul, article .body ol { margin: 0 0 16px 24px; }
    article .body li { margin-bottom: 8px; }
    article .body blockquote { border-left: 3px solid var(--h-teal); padding: 4px 16px; margin: 20px 0; color: var(--h-gray-text); font-style: italic; font-family: var(--font-serif); }

    .generated-section { margin: 34px 0; }
    .generated-section h2 { font-family: var(--font-serif); font-size: 24px; line-height: 1.25; color: var(--h-navy); margin: 0 0 14px; }
    .generated-section p,
    .generated-section li { font-size: 16px; line-height: 1.7; color: var(--h-dark-text); }
    .generated-section p { margin: 0 0 16px; }
    .generated-section ul,
    .generated-section ol,
    article .body ul,
    article .body ol { padding-left: 22px; margin: 14px 0 18px; }
    .generated-section li,
    article .body li { margin: 6px 0; padding-left: 4px; }
    .generated-section li::marker,
    article .body li::marker { color: var(--h-teal-dark); font-size: 0.82em; }
    .generated-section a,
    article .body a { font-weight: 600; }
    article table { width: 100%; border-collapse: separate; border-spacing: 0; table-layout: fixed; margin: 18px 0 24px; border: 1px solid #d8e0eb; border-radius: 6px; overflow: hidden; background: var(--white); font-size: 15px; line-height: 1.45; }
    article th,
    article td { padding: 13px 15px; text-align: left; vertical-align: top; overflow-wrap: anywhere; }
    article th { background: #f1f7f7; color: var(--h-navy); font-size: 12px; line-height: 1.25; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #d8e0eb; }
    article td { color: var(--h-dark-text); border-bottom: 1px solid #eef2f6; }
    article tr:last-child td { border-bottom: 0; }
    article td + td,
    article th + th { border-left: 1px solid #eef2f6; }
    article td a { display: inline; font-weight: 700; color: var(--h-teal-dark); }
    @media (max-width: 640px) {
      article header h1 { font-size: 30px; }
      article table { display: block; overflow-x: auto; table-layout: auto; -webkit-overflow-scrolling: touch; }
      article th,
      article td { min-width: 180px; }
      .generated-section { margin: 28px 0; }
      .generated-section p,
      .generated-section li { font-size: 15.5px; line-height: 1.65; }
    }

    /* ── Takeaways / Callout ── */
    .takeaways { background: var(--h-gray-bg); border-left: 3px solid var(--h-teal); padding: 18px 22px; margin: 24px 0 32px; border-radius: 0 4px 4px 0; }
    .takeaways h3 { font-family: var(--font-serif); font-size: 16px; color: var(--h-navy); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
    .takeaways ul { margin-left: 20px; }
    .takeaways li { margin-bottom: 6px; font-size: 15px; }

    .source-citation { background: #fffbeb; border-left: 3px solid var(--h-accent); padding: 14px 18px; margin: 24px 0; font-size: 14px; color: var(--h-dark-text); border-radius: 0 4px 4px 0; }
    .source-citation a { font-weight: 600; }

    .medical-disclaimer { background: #fef3c7; border-left: 3px solid var(--h-accent); padding: 14px 18px; margin: 24px 0; font-size: 13px; color: #92400e; border-radius: 0 4px 4px 0; }

    /* ── Card Grid ── */
    .cr-card-section { margin: 48px 0 24px; padding-top: 24px; border-top: 1px solid var(--h-gray-light); }
    .cr-card-header { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; justify-content: space-between; margin: 0 0 14px; padding-bottom: 10px; border-bottom: 2px solid var(--h-teal); }
    .cr-card-title { font-family: var(--font-serif); font-size: 22px; color: var(--h-navy); margin: 0; letter-spacing: -0.3px; line-height: 1.3; }
    .cr-card-meta { font-size: 13px; color: var(--h-gray-text); }
    .cr-card-intro { font-size: 14.5px; color: #475569; line-height: 1.6; margin: 0 0 18px; }
    .cr-card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .cr-card { border: 1px solid #d8e0eb; border-radius: 6px; padding: 18px 20px; background: #fff; transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; display: flex; flex-direction: column; gap: 10px; text-decoration: none; color: inherit; }
    .cr-card:hover { border-color: var(--h-teal); box-shadow: 0 4px 16px rgba(13, 148, 136, 0.1); transform: translateY(-1px); text-decoration: none; }
    .cr-card-eyebrow { display: inline-flex; align-items: center; gap: 6px; font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--h-teal); }
    .cr-card-eyebrow::before { content: ""; display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--h-teal); }
    .cr-card-headline { font-family: var(--font-serif); font-size: 16px; margin: 0; color: var(--h-navy); line-height: 1.3; font-weight: 700; }
    .cr-card-tagline { font-size: 13.5px; color: #334155; line-height: 1.5; flex: 1; margin: 0; }
    .cr-card-action { font-size: 13px; font-weight: 600; color: var(--h-teal-dark); margin-top: 4px; }
    .cr-card-action::after { content: " →"; }

    .index-grid { display: grid; grid-template-columns: 1fr; gap: 22px; margin: 24px 0 48px; }
    @media (min-width: 720px) { .index-grid { grid-template-columns: 1fr 1fr; } }
    .index-card { position: relative; background: var(--white); border: 1px solid var(--h-gray-light); border-radius: 6px; padding: 20px 22px; transition: border-color 0.15s, transform 0.15s; cursor: pointer; }
    .index-card:hover { border-color: var(--h-teal); transform: translateY(-1px); }
    .index-card a.card-link { position: absolute; inset: 0; z-index: 1; text-indent: -9999px; overflow: hidden; border-radius: 6px; }
    .index-card a.title-link { position: relative; z-index: 2; font-family: var(--font-serif); font-weight: 700; font-size: 20px; color: var(--h-navy); text-decoration: none; line-height: 1.3; display: block; margin-bottom: 8px; pointer-events: none; }
    .index-card .meta { font-size: 12px; color: var(--h-gray-text); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
    .index-card .summary { font-size: 14px; color: var(--h-dark-text); line-height: 1.55; }

    /* ── Action Buttons ── */
    .btn-primary { display: inline-block; background: var(--h-teal); color: var(--white); padding: 12px 28px; border-radius: 5px; text-decoration: none; font-weight: 600; font-size: 15px; letter-spacing: 0.3px; transition: background 0.15s; border: 0; cursor: pointer; }
    .btn-primary:hover { background: var(--h-teal-dark); color: var(--white); }
    .btn-secondary { display: inline-block; background: var(--white); color: var(--h-navy); padding: 12px 28px; border-radius: 5px; text-decoration: none; font-weight: 600; font-size: 15px; border: 2px solid var(--h-navy); transition: all 0.15s; cursor: pointer; }
    .btn-secondary:hover { background: var(--h-navy); color: var(--white); }

    /* ── Footer Action ── */
    .footer-action { background: var(--h-gray-bg); border-top: 1px solid var(--h-gray-light); padding: 40px 24px; text-align: center; margin-top: 64px; }
    .footer-action h3 { font-family: var(--font-serif); color: var(--h-navy); margin-bottom: 10px; font-size: 24px; }
    .footer-action p { color: var(--h-gray-text); margin-bottom: 20px; max-width: 540px; margin-left: auto; margin-right: auto; }

    .site-footer { background: var(--h-navy-dark); color: rgba(255,255,255,0.65); padding: 28px 24px; text-align: center; font-size: 13px; }
    .site-footer a { color: rgba(255,255,255,0.8); text-decoration: none; margin: 0 8px; }

    /* ── Cluster Pills ── */
    .cluster-pill { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; padding: 4px 10px; border-radius: 3px; }
    .cluster-pill.metabolism { background: #dbeafe; color: #1e40af; }
    .cluster-pill.hormones { background: #fef3c7; color: #92400e; }
    .cluster-pill.recovery { background: #d1fae5; color: #065f46; }
    .cluster-pill.testing { background: #ede9fe; color: #5b21b6; }
    .cluster-pill.peptides { background: #fce7f3; color: #9d174d; }

    /* ── Share Button ── */
    .share-btn { background: transparent; border: 1px solid var(--h-gray-light); border-radius: 999px; padding: 6px 14px; font-family: var(--font-sans); font-size: 12px; font-weight: 600; color: var(--h-gray-text); cursor: pointer; display: inline-flex; align-items: center; gap: 6px; line-height: 1; transition: color 0.15s, border-color 0.15s, background 0.15s; text-decoration: none; }
    .share-btn:hover { color: var(--h-teal); border-color: var(--h-teal); }
    .share-btn.copied { color: #166534; border-color: #166534; background: #f0fdf4; }
    .share-toast { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--h-navy); color: var(--white); padding: 10px 20px; border-radius: 999px; font-family: var(--font-sans); font-size: 13px; font-weight: 600; box-shadow: 0 8px 24px rgba(0,0,0,0.18); opacity: 0; pointer-events: none; transition: opacity 0.2s ease, transform 0.2s ease; z-index: 9999; }
    .share-toast.is-visible { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ── Feedback Widget ── */
    .feedback-widget { position: fixed; right: 24px; bottom: 24px; z-index: 9998; font-family: var(--font-sans); }
    .feedback-pill { appearance: none; border: 1px solid rgba(12,31,63,0.12); background: var(--h-navy); color: var(--white); border-radius: 999px; padding: 10px 18px; font: 700 13px/1 var(--font-sans); letter-spacing: 0.2px; box-shadow: 0 10px 28px rgba(12,31,63,0.22); cursor: pointer; transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease; }
    .feedback-pill:hover { background: var(--h-teal-dark); transform: translateY(-1px); box-shadow: 0 12px 32px rgba(12,31,63,0.26); }
    .feedback-panel { position: absolute; right: 0; bottom: 52px; width: min(360px, calc(100vw - 48px)); background: var(--white); border: 1px solid var(--h-gray-light); border-radius: 8px; box-shadow: 0 18px 48px rgba(12,31,63,0.2); padding: 18px; opacity: 0; pointer-events: none; transform: translateY(8px); transition: opacity 0.18s ease, transform 0.18s ease; }
    .feedback-widget.is-open .feedback-panel { opacity: 1; pointer-events: auto; transform: translateY(0); }
    .feedback-panel-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
    .feedback-title { font-family: var(--font-serif); color: var(--h-navy); font-size: 18px; line-height: 1.25; margin: 0; }
    .feedback-close { appearance: none; border: 0; background: transparent; color: var(--h-gray-text); cursor: pointer; font-size: 22px; line-height: 1; padding: 0 2px; }
    .feedback-close:hover { color: var(--h-navy); }
    .feedback-help { color: var(--h-gray-text); font-size: 13.5px; line-height: 1.5; margin: 0 0 12px; }
    .feedback-form { display: grid; gap: 10px; }
    .feedback-form textarea { width: 100%; min-height: 112px; resize: vertical; border: 1px solid #cbd5e1; border-radius: 6px; padding: 11px 12px; font: 14px/1.45 var(--font-sans); color: var(--h-dark-text); }
    .feedback-form textarea:focus { outline: 2px solid rgba(13,148,136,0.22); border-color: var(--h-teal); }
    .feedback-submit { justify-self: start; }
    .feedback-status { min-height: 18px; font-size: 12.5px; line-height: 1.4; color: var(--h-gray-text); }
    .feedback-status.is-success { color: #166534; }
    .feedback-status.is-error { color: #b91c1c; }
    @media (max-width: 768px) {
      .feedback-widget { display: none; }
    }
  </style>

  {% block head_extra %}{% endblock %}
</head>
<body>

<nav class="top-nav">
  <div class="top-nav-inner">
    <a class="nav-brand" href="/">
      <span class="brand-icon">
        <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <g fill="none" stroke="#1264b0" stroke-width="30" stroke-linejoin="round">
            <path d="M118 112h86c53 0 96 43 96 96v22h-86c-53 0-96-43-96-96z"/>
            <path d="M394 112h-86c-53 0-96 43-96 96v22h86c53 0 96-43 96-96z"/>
            <path d="M118 400h86c53 0 96-43 96-96v-22h-86c-53 0-96 43-96 96z"/>
            <path d="M394 400h-86c-53 0-96-43-96-96v-22h86c53 0 96 43 96 96z"/>
          </g>
        </svg>
      </span>
      {{ _site_name }}
    </a>
    <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <div class="nav-links" id="primary-nav">
      <a href="/how-it-works">How It Works</a>
      <a href="/guides">Guides</a>
      <a href="/briefing">Articles</a>
      <a href="/tools">Tools</a>
      <a href="/about">About</a>
      <a href="/assessment" class="nav-action">Free Assessment</a>
    </div>
  </div>
</nav>

{% macro share_button(url, title, label='Share') -%}
<button type="button" class="share-btn"
        data-share-url="{{ url }}"
        data-share-title="{{ title|e }}"
        aria-label="Share this page">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
  </svg>
  <span class="share-btn-label">{{ label }}</span>
</button>
{%- endmacro %}

<main>
{% block content %}{% endblock %}
</main>

<div class="feedback-widget" data-feedback-widget>
  <button type="button" class="feedback-pill" data-feedback-open aria-expanded="false" aria-controls="feedback-panel">Feedback</button>
  <section class="feedback-panel" id="feedback-panel" aria-labelledby="feedback-title" hidden>
    <div class="feedback-panel-header">
      <h2 class="feedback-title" id="feedback-title">Help us make this more useful</h2>
      <button type="button" class="feedback-close" data-feedback-close aria-label="Close feedback panel">&times;</button>
    </div>
    <p class="feedback-help">What would make Metabolic Journal better for you? New tools, clearer guides, missing topics, anything.</p>
    <form class="feedback-form" data-feedback-form novalidate>
      <textarea name="feedback" maxlength="2000" required placeholder="Tell us what you wish this site could help you do..." aria-label="Feedback"></textarea>
      <button type="button" class="btn-primary feedback-submit" data-feedback-submit>Send feedback</button>
      <div class="feedback-status" data-feedback-status role="status" aria-live="polite"></div>
    </form>
  </section>
</div>

{% block footer_action %}
<div class="footer-action">
  <h3>Understand your health — on your terms</h3>
  <p>Use our free tools and evidence-based guides to make smarter decisions about your metabolism, hormones, and recovery.</p>
  <a class="btn-primary" href="/assessment">Take the Free Assessment →</a>
</div>
{% endblock %}

