{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .page-hero {
    background: linear-gradient(135deg, var(--h-navy) 0%, var(--h-navy-dark) 100%);
    color: var(--white);
    padding: 56px 24px 52px;
    text-align: center;
  }
  .page-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(32px, 3.8vw, 48px);
    line-height: 1.12;
    max-width: 980px;
    margin: 0 auto 16px;
    text-wrap: balance;
  }
  .page-hero p {
    color: rgba(255,255,255,0.75);
    font-size: 17px;
    max-width: 680px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .doc-section { padding: 48px 0; border-bottom: 1px solid var(--h-gray-light); }
  .doc-section:last-of-type { border-bottom: 0; }
  .doc-section h2 { font-family: var(--font-serif); font-size: 24px; color: var(--h-navy); margin-bottom: 16px; }

  .spec-intro { color: var(--h-dark-text); margin-bottom: 20px; }
  .spec-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--h-gray-light);
  }
  .spec-card {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 18px;
    align-items: start;
    padding: 18px 0;
    border-bottom: 1px solid var(--h-gray-light);
    text-align: left;
  }
  .spec-icon { display: none; }
  .spec-card h3 { font-family: var(--font-sans); font-size: 14px; color: var(--h-navy); margin: 2px 0 0; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
  .spec-card p { font-size: 14.5px; color: var(--h-gray-text); line-height: 1.55; margin: 0; }
  @media (max-width: 640px) {
    .page-hero { padding: 44px 22px 42px; }
    .page-hero h1 { font-size: clamp(30px, 9vw, 38px); }
    .spec-card { grid-template-columns: 1fr; gap: 6px; }
  }

  .process-list { list-style: none; padding: 0; counter-reset: proc; margin-top: 20px; }
  .process-list li {
    counter-increment: proc;
    padding: 18px 0 18px 56px;
    border-bottom: 1px solid var(--h-gray-light);
    position: relative;
    font-size: 15px;
    line-height: 1.6;
  }
  .process-list li:last-child { border-bottom: 0; }
  .process-list li::before {
    content: counter(proc);
    position: absolute;
    left: 0;
    top: 18px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--h-teal);
    color: var(--white);
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .process-list li strong { color: var(--h-navy); }

  .trust-points {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 24px;
  }
  .trust-point {
    flex: 1;
    min-width: 200px;
    background: var(--h-gray-bg);
    border-radius: 6px;
    padding: 20px;
  }
  .trust-point h4 { font-size: 14px; color: var(--h-navy); margin-bottom: 6px; }
  .trust-point p { font-size: 13.5px; color: var(--h-gray-text); line-height: 1.5; margin: 0; }

  .booking-cta {
    text-align: center;
    padding: 56px 24px;
    background: var(--h-gray-bg);
    border-radius: 8px;
    margin: 48px 0;
  }
  .booking-cta h2 { font-family: var(--font-serif); color: var(--h-navy); font-size: 28px; margin-bottom: 14px; }
  .booking-cta p { color: var(--h-gray-text); max-width: 500px; margin: 0 auto 24px; }

  .booking-form {
    max-width: 480px;
    margin: 0 auto;
    text-align: left;
  }
  .form-group { margin-bottom: 20px; }
  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--h-navy);
    margin-bottom: 6px;
  }
  .form-group input, .form-group select, .form-group textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--h-gray-light);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--h-dark-text);
  }
  .form-group textarea { resize: vertical; min-height: 80px; }
</style>
{% endblock %}

{% block footer_action %}{% endblock %}

{% block content %}
<section class="page-hero">
  <h1>Book a specialist appointment</h1>
  <p>Tell us what you need help with. We'll match you with the right specialist for metabolic health, hormones, sleep, or complex fatigue.</p>
</section>

<div class="container">
  <nav class="breadcrumbs">
    <a href="/">Home</a> <span>/</span> Book a Specialist
  </nav>

  <div class="doc-section">
    <h2>Specialties We Cover</h2>
    <p class="spec-intro">These are the clinical areas we use to route your request. You do not need to choose from this list here; the form below captures your concern.</p>
    <div class="spec-grid">
      <div class="spec-card">
        <h3>Endocrinology</h3>
        <p>Hormone imbalances, thyroid disorders, testosterone, estrogen, cortisol, and adrenal function.</p>
      </div>
      <div class="spec-card">
        <h3>Metabolic Medicine</h3>
        <p>Insulin resistance, type 2 diabetes prevention, metabolic syndrome, and weight management.</p>
      </div>
      <div class="spec-card">
        <h3>Sleep Medicine</h3>
        <p>Sleep apnea, chronic insomnia, circadian rhythm disorders, and fatigue investigation.</p>
      </div>
      <div class="spec-card">
        <h3>Functional Medicine</h3>
        <p>Root-cause approaches to chronic fatigue, autoimmune patterns, gut health, and complex cases.</p>
      </div>
    </div>
  </div>

  <div class="doc-section">
    <h2>How the Matching Works</h2>
    <p>There's no marketplace to browse. You tell us what you need, and we find the right fit.</p>
    <ol class="process-list">
      <li><strong>Submit your request</strong> — Tell us your primary concern, location, and any preferences (telehealth vs. in-person, insurance, etc.).</li>
      <li><strong>We review and match</strong> — Our team reviews your request and identifies the best specialist from our vetted network based on specialty, location, availability, and your specific needs.</li>
      <li><strong>You get introduced</strong> — We send you the doctor's profile, credentials, and scheduling link. You decide if it's the right fit.</li>
      <li><strong>Book directly</strong> — Schedule directly with the doctor's office. No middleman fees for the appointment itself.</li>
    </ol>
  </div>

  <div class="doc-section">
    <h2>Our Vetting Standards</h2>
    <div class="trust-points">
      <div class="trust-point">
        <h3>Board Certified</h3>
        <p>All doctors in our network are board-certified in their specialty with active medical licenses.</p>
      </div>
      <div class="trust-point">
        <h3>Evidence-Based</h3>
        <p>We only work with practitioners who use evidence-based approaches grounded in clinical research.</p>
      </div>
      <div class="trust-point">
        <h3>Optimal Ranges</h3>
        <p>Our doctors interpret labs against functional optimal ranges, not just standard pathology thresholds.</p>
      </div>
      <div class="trust-point">
        <h3>Patient-First</h3>
        <p>No upselling, no unnecessary tests, no pill-for-every-symptom approach. Root-cause investigation first.</p>
      </div>
    </div>
  </div>

  <div class="booking-cta">
    <h2>Book An Appointment With A Specialist</h2>
    <p>Tell us what you're dealing with. We'll find the right specialist and introduce you within 48 hours.</p>
    {% if request.args.get('error') == 'invalid-email' %}
    <p style="color:#b91c1c; font-size:14px; margin-bottom:16px;">Please enter a valid email address.</p>
    {% endif %}
    <form class="booking-form" action="/api/doctor-request" method="POST">
      <input type="hidden" name="source" value="{{ source|default('direct') }}">
      <input type="hidden" name="result_context" value="{{ result_context|default('') }}">
      <div class="form-group">
        <label for="dr-name">Your Name</label>
        <input type="text" id="dr-name" name="name" required>
      </div>
      <div class="form-group">
        <label for="dr-email">Email</label>
        <input type="email" id="dr-email" name="email" required>
      </div>
      <div class="form-group">
        <label for="dr-concern">Primary Concern</label>
        <select id="dr-concern" name="concern" required>
          <option value="">Select one...</option>
          <option value="hormones" {% if selected_concern == 'hormones' %}selected{% endif %}>Hormone imbalance (testosterone, thyroid, estrogen, cortisol)</option>
          <option value="metabolic" {% if selected_concern == 'metabolic' %}selected{% endif %}>Metabolic issues (insulin resistance, weight, blood sugar)</option>
          <option value="sleep" {% if selected_concern == 'sleep' %}selected{% endif %}>Sleep problems (apnea, insomnia, fatigue)</option>
          <option value="fatigue" {% if selected_concern == 'fatigue' %}selected{% endif %}>Chronic fatigue (unexplained tiredness)</option>
          <option value="general" {% if selected_concern == 'general' %}selected{% endif %}>Not sure — need help figuring it out</option>
        </select>
      </div>
      <div class="form-group">
        <label for="dr-location">Location / Telehealth Preference</label>
        <input type="text" id="dr-location" name="location" placeholder="City, state, or telehealth only" required>
      </div>
      <div class="form-group">
        <label for="dr-pref">What are you hoping to get help with?</label>
        <textarea id="dr-pref" name="preferences" placeholder="Symptoms, abnormal labs, treatment questions, insurance preferences, or anything else we should know."></textarea>
      </div>
      <button type="submit" class="btn-primary" style="width:100%; text-align:center;">Book An Appointment With A Specialist →</button>
      <p style="font-size:12px; color:var(--h-gray-text); text-align:center; margin-top:10px;">Free to submit. No obligation. We'll respond within 48 hours.</p>
    </form>
  </div>

  <div class="medical-disclaimer" style="margin-top:32px;">
    <strong>Disclaimer:</strong> We facilitate introductions to qualified healthcare providers. We are not a medical practice and do not provide medical advice, diagnoses, or treatment. All medical decisions are made between you and your doctor. The doctors in our network are independent practitioners — we do not employ them or control their clinical decisions.
  </div>
</div>
{% endblock %}
