{% extends "_base.html.j2" %}
{% from "_cluster_nav.html.j2" import cluster_nav, cluster_nav_css %}

{% block head_extra %}
{{ cluster_nav_css() }}
<style>
  .filter-bar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin: 0 0 24px; }
  .filter-btn { background: var(--white); border: 1px solid var(--h-gray-light); border-radius: 4px; padding: 8px 16px; font-size: 13px; font-weight: 600; color: var(--h-gray-text); cursor: pointer; transition: all 0.15s; }
  .filter-btn:hover { border-color: var(--h-teal); color: var(--h-teal); }
  .filter-btn.is-active { background: var(--h-teal); border-color: var(--h-teal); color: var(--white); }
  .empty-state { text-align: center; padding: 48px 24px; color: var(--h-gray-text); }
</style>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Articles</span>
  </nav>

  <header style="margin: 16px 0 24px;">
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--h-navy); margin:0 0 10px;">Health Optimization Briefings</h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--h-gray-text); font-size:18px; max-width:680px;">
      Evidence-based analysis on metabolism, hormones, recovery, and biomarkers — written for people who want results, not filler.
    </p>
  </header>

  {{ cluster_nav() }}

  {% if posts %}
  <div class="filter-bar" role="toolbar" aria-label="Filter by cluster">
    <button type="button" class="filter-btn is-active" data-filter="all">All</button>
    <button type="button" class="filter-btn" data-filter="metabolism">Metabolism</button>
    <button type="button" class="filter-btn" data-filter="hormones">Hormones</button>
    <button type="button" class="filter-btn" data-filter="recovery">Recovery</button>
    <button type="button" class="filter-btn" data-filter="testing">Testing</button>
  </div>

  <div class="index-grid" id="posts-grid">
    {% for p in posts %}
    <article class="index-card" data-cluster="{{ p.primary_cluster or '' }}">
      <a class="card-link" href="/briefing/{{ p.slug }}">{{ p.title }}</a>
      <div class="meta">
        {% if p.primary_cluster %}
        <span class="cluster-pill {{ p.primary_cluster }}">{{ p.primary_cluster|replace('_',' ')|title }}</span> ·
        {% endif %}
        {{ p.published_date.strftime('%b %d, %Y') }}
        {% if p.reading_minutes %} · {{ p.reading_minutes }} min read{% endif %}
      </div>
      <a class="title-link" href="/briefing/{{ p.slug }}">{{ p.title }}</a>
      {% if p.summary %}<p class="summary">{{ p.summary|truncate(160) }}</p>{% endif %}
    </article>
    {% endfor %}
  </div>

  <div class="empty-state" id="empty-filter" style="display:none;">
    <p>No articles in this category yet. Check back soon.</p>
  </div>

  {% else %}
  <div class="empty-state">
    <p>No articles published yet. New briefings are published daily.</p>
  </div>
  {% endif %}

  <div style="text-align:center; margin: 32px 0 48px;">
    <a href="/assessment" class="btn-primary">Get Your Personalized Protocol →</a>
  </div>

</section>

<script>
(function () {
  var buttons = document.querySelectorAll('.filter-btn[data-filter]');
  var cards = document.querySelectorAll('.index-card[data-cluster]');
  var empty = document.getElementById('empty-filter');
  if (!buttons.length) return;

  buttons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      buttons.forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      var filter = btn.getAttribute('data-filter');
      var visible = 0;
      cards.forEach(function (card) {
        var show = filter === 'all' || card.getAttribute('data-cluster') === filter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    });
  });
})();
</script>
{% endblock %}
