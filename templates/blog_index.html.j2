{% extends "_base.html.j2" %}
{% from "_cluster_nav.html.j2" import cluster_nav, cluster_nav_css %}

{% block head_extra %}
{{ cluster_nav_css() }}
<style>
  .cluster-section { margin-bottom: 48px; }
  .cluster-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 2px solid var(--h-navy);
    padding-bottom: 10px;
    margin-bottom: 20px;
  }
  .cluster-header h2 { font-family: var(--font-serif); font-size: 24px; color: var(--h-navy); margin: 0; }
  .cluster-header .cluster-count { font-size: 13px; color: var(--h-gray-text); font-weight: 600; }
  .article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; }
  .article-card {
    background: white;
    border: 1px solid var(--h-gray-light);
    border-radius: 8px;
    padding: 20px 22px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-card:hover { border-color: var(--h-teal); box-shadow: 0 3px 16px rgba(13,148,136,0.08); }
  .article-card .ac-type {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 8px;
  }
  .ac-type.metabolism { color: #059669; }
  .ac-type.hormones { color: #7c3aed; }
  .ac-type.recovery { color: #2563eb; }
  .ac-type.testing { color: #d97706; }
  .article-card .ac-title { font-size: 15px; font-weight: 600; color: var(--h-navy); line-height: 1.4; margin-bottom: 8px; }
  .article-card .ac-summary { font-size: 13px; color: var(--h-gray-text); line-height: 1.5; flex: 1; }
</style>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Articles</span>
  </nav>

  <header style="margin: 16px 0 32px;">
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--h-navy); margin:0 0 10px;">Health Articles &amp; Guides</h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--h-gray-text); font-size:18px; max-width:680px;">
      Evidence-based guides on metabolism, hormones, recovery, and biomarkers — written for people who want results, not filler.
    </p>
  </header>

  {{ cluster_nav() }}

  {% if articles_by_cluster %}
  {% set cluster_names = {"metabolism": "Metabolic Health", "hormones": "Hormone Optimization", "recovery": "Sleep & Recovery", "testing": "Testing & Biomarkers"} %}
  {% for cluster_key in ["metabolism", "hormones", "recovery", "testing"] %}
  {% set items = articles_by_cluster.get(cluster_key, []) %}
  {% if items %}
  <div class="cluster-section" id="section-{{ cluster_key }}">
    <div class="cluster-header">
      <h2>{{ cluster_names[cluster_key] }}</h2>
      <span class="cluster-count">{{ items|length }} article{{ 's' if items|length != 1 }}</span>
    </div>
    <div class="article-grid">
      {% for item in items %}
      <a href="{{ item.path }}" class="article-card">
        {% set cluster_labels = {"metabolism": "Metabolism", "hormones": "Hormones", "recovery": "Sleep & Recovery", "testing": "Testing"} %}
        <span class="ac-type {{ item.cluster }}">{{ cluster_labels.get(item.cluster, item.cluster|title) }}</span>
        <div class="ac-title">{{ item.title }}</div>
        {% if item.summary %}<div class="ac-summary">{{ item.summary|truncate(140) }}</div>{% endif %}
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  {% endfor %}
  {% endif %}


</section>
{% endblock %}
