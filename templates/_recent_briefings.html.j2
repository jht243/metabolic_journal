{#
  Recent briefings card grid partial.

  Usage:
    {% from "_recent_briefings.html.j2" import recent_briefings %}
    {{ recent_briefings(posts, limit=3) }}
#}

{% macro recent_briefings(posts, limit=3) %}
{% set display_posts = posts[:limit] %}
{% if display_posts %}
<section class="cr-card-section" aria-label="Recent articles">
  <div class="cr-card-header">
    <h2 class="cr-card-title">Latest Health Briefings</h2>
    <a href="/briefing" class="cr-card-meta" style="text-decoration:underline;">View all →</a>
  </div>
  <div class="cr-card-grid">
    {% for p in display_posts %}
    <a class="cr-card" href="/briefing/{{ p.slug }}">
      <span class="cr-card-eyebrow">{{ (p.primary_cluster or 'Health')|replace('_',' ')|title }}</span>
      <h3 class="cr-card-headline">{{ p.title }}</h3>
      {% if p.summary %}<p class="cr-card-tagline">{{ p.summary|truncate(120) }}</p>{% endif %}
      <span class="cr-card-action">Read article</span>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}
{% endmacro %}
