{% extends "_base.html.j2" %}
{% from "_base.html.j2" import share_button %}
{% from "_recent_briefings.html.j2" import recent_briefings %}
{% from "_cta.html.j2" import cta_assessment, cta_lead_magnet, cta_inline %}
{% from "_cluster_nav.html.j2" import cluster_nav %}
{% from "_eeat.html.j2" import reviewer_badge, medical_schema %}

{% block head_extra %}
{% if post %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ post.title|tojson }},
  {% if post.subtitle %}"alternativeHeadline": {{ post.subtitle|tojson }},{% endif %}
  "datePublished": "{{ post.published_date.isoformat() }}",
  {% if post.updated_at %}"dateModified": "{{ post.updated_at.strftime('%Y-%m-%d') }}",{% endif %}
  "author": {
    "@type": "Organization",
    "name": "{{ site_name|default('REPLACE_ME_SITE_NAME') }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site_name|default('REPLACE_ME_SITE_NAME') }}"
  },
  {% if post.summary %}"description": {{ post.summary|tojson }},{% endif %}
  {% if post.word_count %}"wordCount": {{ post.word_count }},{% endif %}
  {% if post.canonical_source_url %}"citation": {{ post.canonical_source_url|tojson }},{% endif %}
  {% if post.reviewed_by %}"reviewedBy": { "@type": "Person", "name": {{ post.reviewed_by|tojson }} },{% endif %}
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ request.url|default('') }}"
  }
}
</script>
{% endif %}
{% endblock %}

{% block content %}
<article class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/briefing">Articles</a><span>/</span>
    <span>{{ post.title|truncate(50) }}</span>
  </nav>

  <header>
    {% if post.primary_cluster %}
    <span class="cluster-pill {{ post.primary_cluster }}">{{ post.primary_cluster|replace('_',' ')|title }}</span>
    {% endif %}
    <h1>{{ post.title }}</h1>
    {% if post.subtitle %}<p class="subtitle">{{ post.subtitle }}</p>{% endif %}
    <div class="meta">
      <span><strong>Published</strong> {{ post.published_date.strftime('%B %d, %Y') }}</span>
      {% if post.reading_minutes %}<span><strong>Read</strong> {{ post.reading_minutes }} min</span>{% endif %}
      {% if post.word_count %}<span>{{ post.word_count|int }} words</span>{% endif %}
      {% if post.primary_cluster %}<span><strong>Topic</strong> {{ post.primary_cluster|replace('_',' ')|title }}</span>{% endif %}
      <span style="margin-left:auto;">{{ share_button(request.url|default('/briefing/' ~ post.slug), post.title) }}</span>
    </div>
  </header>

  {% if post.reviewed_by %}
  <div style="font-size:13px; color:var(--h-gray-text); margin-bottom:16px; padding:8px 0; border-bottom:1px solid var(--h-gray-light);">
    <strong>Reviewed by:</strong> {{ post.reviewed_by }}
    {% if post.reviewed_at %} · {{ post.reviewed_at.strftime('%B %Y') }}{% endif %}
  </div>
  {% endif %}

  {% set takeaways = post.takeaways_json if post.takeaways_json else none %}
  {% if takeaways %}
  <aside class="takeaways" aria-label="Key takeaways">
    <h3>Key Takeaways</h3>
    <ul>
      {% for t in takeaways %}<li>{{ t }}</li>{% endfor %}
    </ul>
  </aside>
  {% endif %}

  <div class="body">
    {{ post.body_html | safe }}
  </div>

  <div class="medical-disclaimer">
    <strong>Medical Disclaimer:</strong> This content is for informational purposes only and does not constitute medical advice. Always consult a qualified healthcare provider before making changes to your health regimen.
  </div>

  {% if post.canonical_source_url %}
  <div class="source-citation">
    <strong>Primary source:</strong>
    <a href="{{ post.canonical_source_url }}" rel="nofollow noopener" target="_blank">{{ source_label|default('View original source') }}</a>
    — referenced for fact-checking; this analysis is independent editorial content.
  </div>
  {% endif %}

  <div style="display:flex; align-items:center; gap:14px; margin:24px 0 8px; padding:14px 0; border-top:1px solid var(--h-gray-light);">
    <span style="font-size:13px; color:var(--h-gray-text);">Found this useful?</span>
    {{ share_button(request.url|default('/briefing/' ~ post.slug), post.title, label='Share article') }}
  </div>

  {% if related %}
  <section class="cr-card-section" aria-label="Related articles">
    <div class="cr-card-header">
      <h2 class="cr-card-title">Related Articles</h2>
    </div>
    <div class="cr-card-grid">
      {% for r in related %}
      <a class="cr-card" href="/briefing/{{ r.slug }}">
        <span class="cr-card-eyebrow">{{ (r.primary_cluster or 'Health')|replace('_',' ')|title }}</span>
        <h3 class="cr-card-headline">{{ r.title }}</h3>
        {% if r.summary %}<p class="cr-card-tagline">{{ r.summary|truncate(100) }}</p>{% endif %}
        <span class="cr-card-action">Read article</span>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if post.cluster %}
  {{ cluster_nav(post.cluster) }}
  {% endif %}

  {{ cta_assessment(heading="Understand Your Health Better", subtext="Our free assessment maps your symptoms to the most relevant guides, tools, and product recommendations.") }}

</article>
{% endblock %}
