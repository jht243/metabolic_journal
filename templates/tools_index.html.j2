{% extends "_base.html.j2" %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <span>Tools</span>
  </nav>

  <header style="margin:16px 0 32px;">
    <h1 style="font-family:var(--font-serif); font-size:36px; color:var(--h-navy); margin:0 0 10px;">Health Optimization Tools</h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--h-gray-text); font-size:18px; max-width:680px;">
      Free clinical calculators to help you understand your metabolic health, hormone status, and recovery capacity.
    </p>
  </header>

  {% set tools = [
    {
      'slug': 'energy-assessment',
      'name': 'Energy Assessment',
      'description': 'Evaluate your daily energy patterns to identify metabolic bottlenecks and fatigue triggers. Get a personalized energy score with actionable recommendations.'
    },
    {
      'slug': 'metabolic-score',
      'name': 'Metabolic Score Calculator',
      'description': 'Calculate your metabolic efficiency score based on key biomarkers — fasting glucose, insulin, triglycerides, and waist circumference.'
    },
    {
      'slug': 'hormone-checker',
      'name': 'Hormone Symptom Checker',
      'description': 'Map your symptoms to potential hormonal imbalances. Covers thyroid, cortisol, testosterone, estrogen, and insulin dysregulation patterns.'
    },
    {
      'slug': 'sleep-score',
      'name': 'Sleep Recovery Score',
      'description': 'Assess your sleep quality and recovery capacity. Identifies sleep architecture issues and provides evidence-based improvement strategies.'
    },
    {
      'slug': 'insulin-resistance-calculator',
      'name': 'Insulin Resistance Calculator',
      'description': 'Estimate your insulin resistance risk using the HOMA-IR model and additional metabolic markers. Early detection enables early intervention.'
    }
  ] %}

  <div class="cr-card-grid">
    {% for tool in tools %}
    <a class="cr-card" href="/tools/{{ tool.slug }}">
      <span class="cr-card-eyebrow">Free Tool</span>
      <h2 class="cr-card-headline">{{ tool.name }}</h2>
      <p class="cr-card-tagline">{{ tool.description }}</p>
      <span class="cr-card-cta">Use calculator</span>
    </a>
    {% endfor %}
  </div>

  <div style="text-align:center; margin:48px 0 32px;">
    <p style="color:var(--h-gray-text); margin-bottom:16px; font-size:15px;">Want a comprehensive analysis that combines all these metrics?</p>
    <a href="/assessment" class="btn-primary">Get Your Full Assessment →</a>
  </div>

</section>
{% endblock %}
