{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .assess-hero {
    background: linear-gradient(135deg, var(--h-navy) 0%, var(--h-navy-dark) 100%);
    color: var(--white);
    padding: 72px 24px 64px;
    text-align: center;
  }
  .assess-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(30px, 5vw, 42px);
    margin-bottom: 16px;
  }
  .assess-hero p {
    color: rgba(255,255,255,0.75);
    font-size: 18px;
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.55;
  }

  .assess-content { padding: 56px 0; }

  .covers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }
  .cover-item {
    background: var(--h-gray-bg);
    border-radius: 6px;
    padding: 22px 20px;
    text-align: center;
  }
  .cover-item .cover-icon { font-size: 28px; margin-bottom: 10px; }
  .cover-item h3 { font-family: var(--font-serif); font-size: 16px; color: var(--h-navy); margin-bottom: 6px; }
  .cover-item p { font-size: 13.5px; color: var(--h-gray-text); line-height: 1.5; }

  .get-section h2 { font-family: var(--font-serif); font-size: 24px; color: var(--h-navy); margin-bottom: 20px; }
  .get-list { list-style: none; padding: 0; margin-bottom: 48px; }
  .get-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--h-gray-light);
    font-size: 15px;
  }
  .get-list li:last-child { border-bottom: 0; }
  .get-check {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--h-teal); color: var(--white);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; flex-shrink: 0; margin-top: 1px;
  }

  .trust-badges {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 40px;
  }
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--h-gray-text);
  }
  .trust-badge svg { color: var(--h-teal); flex-shrink: 0; }

  .start-cta {
    text-align: center;
    padding: 48px 24px;
    background: var(--h-gray-bg);
    border-radius: 8px;
  }
  .start-cta .btn-primary { font-size: 18px; padding: 16px 40px; }
  .start-cta p { color: var(--h-gray-text); font-size: 13px; margin-top: 12px; }
</style>
{% endblock %}

{% block content %}
<section class="assess-hero">
  <h1>Find Out Where You Stand</h1>
  <p>Answer a few questions about your symptoms, goals, and lifestyle. Get personalized insights and recommendations — instantly and for free.</p>
</section>

<div class="container">
  <nav class="breadcrumbs">
    <a href="/">Home</a> <span>/</span> Assessment
  </nav>

  <div class="assess-content">
    <h2 style="font-family:var(--font-serif); font-size:24px; color:var(--h-navy); text-align:center; margin-bottom:28px;">What the Assessment Covers</h2>
    <div class="covers-grid">
      <div class="cover-item">
        <div class="cover-icon">📋</div>
        <h3>Symptoms</h3>
        <p>Current symptoms across metabolic, hormonal, and recovery areas</p>
      </div>
      <div class="cover-item">
        <div class="cover-icon">🎯</div>
        <h3>Goals</h3>
        <p>What you want to improve and your health priorities</p>
      </div>
      <div class="cover-item">
        <div class="cover-icon">📊</div>
        <h3>Health History</h3>
        <p>Past conditions, medications, and relevant context</p>
      </div>
      <div class="cover-item">
        <div class="cover-icon">⚙️</div>
        <h3>Lifestyle</h3>
        <p>Diet patterns, exercise habits, sleep routine, and stress levels</p>
      </div>
    </div>

    <div class="get-section">
      <h2>What You'll Get</h2>
      <ul class="get-list">
        <li>
          <span class="get-check">✓</span>
          <span><strong>Risk snapshot</strong> — see where your metabolic, hormonal, and recovery health stands based on your symptoms and lifestyle factors</span>
        </li>
        <li>
          <span class="get-check">✓</span>
          <span><strong>Recommended reading</strong> — the most relevant guides and tools surfaced based on your specific answers</span>
        </li>
        <li>
          <span class="get-check">✓</span>
          <span><strong>Next steps</strong> — which lab tests to ask your doctor about, product recommendations, or whether to connect with a specialist</span>
        </li>
      </ul>
    </div>

    <div class="trust-badges">
      <span class="trust-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Takes 5 minutes
      </span>
      <span class="trust-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
        100% free
      </span>
      <span class="trust-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="8.5" cy="7" r="4"/><path d="M20 8v6M23 11h-6"/></svg>
        Research-backed questions
      </span>
    </div>

    <div class="start-cta">
      <a href="/assessment/quiz" class="btn-primary">Start the Assessment →</a>
      <p>Free. No account required. Your data stays private.</p>
    </div>
  </div>
</div>
{% endblock %}
