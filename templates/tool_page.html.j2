{% block scripts_extra %}
<script>
function _$(id){return document.getElementById(id)}
function _v(id){var e=_$(id);return e?parseFloat(e.value):NaN}
function _sv(id){var e=_$(id);return e?e.value:''}
function _show(id,html){var el=_$(id);el.innerHTML=html;el.classList.add('show');el.scrollIntoView({behavior:'smooth',block:'nearest'})}
function _bar(pct,color){return '<div class="result-bar"><div class="result-bar-fill" style="width:'+pct+'%;background:'+color+'"></div></div>'}
function _riskClass(level){return level==='low'?'risk-low':level==='moderate'?'risk-moderate':'risk-high'}
function _riskColor(level){return level==='low'?'#059669':level==='moderate'?'#d97706':'#dc2626'}

/* ── Metabolic Health Score Calculator ── */
function calcMetabolic(e){
  e.preventDefault();
  var sex=_sv('ms-sex'),waist=_v('ms-waist'),trig=_v('ms-trig'),hdl=_v('ms-hdl'),
      sbp=_v('ms-sbp'),dbp=_v('ms-dbp'),glucose=_v('ms-glucose');
  var score=0,total=0,details=[];
  if(!isNaN(waist)){total++;
    var ok=sex==='female'?waist<35:waist<40;
    if(ok){score++;details.push({label:'Waist Circumference',val:waist+'"',status:'Optimal',risk:'low'})}
    else{details.push({label:'Waist Circumference',val:waist+'"',status:'Above threshold ('+(sex==='female'?'≥35"':'≥40"')+')',risk:'high'})}
  }
  if(!isNaN(trig)){total++;
    if(trig<150){score++;details.push({label:'Triglycerides',val:trig+' mg/dL',status:'Optimal (<150)',risk:'low'})}
    else{details.push({label:'Triglycerides',val:trig+' mg/dL',status:'Elevated (≥150)',risk:trig>=200?'high':'moderate'})}
  }
  if(!isNaN(hdl)){total++;
    var hdlOk=sex==='female'?hdl>=50:hdl>=40;
    if(hdlOk){score++;details.push({label:'HDL Cholesterol',val:hdl+' mg/dL',status:'Optimal',risk:'low'})}
    else{details.push({label:'HDL Cholesterol',val:hdl+' mg/dL',status:'Below threshold ('+(sex==='female'?'<50':'<40')+')',risk:'high'})}
  }
  if(!isNaN(sbp)&&!isNaN(dbp)){total++;
    if(sbp<120&&dbp<80){score++;details.push({label:'Blood Pressure',val:sbp+'/'+dbp+' mmHg',status:'Optimal',risk:'low'})}
    else{details.push({label:'Blood Pressure',val:sbp+'/'+dbp+' mmHg',status:sbp>=140||dbp>=90?'High':'Elevated',risk:sbp>=140||dbp>=90?'high':'moderate'})}
  }
  if(!isNaN(glucose)){total++;
    if(glucose<100){score++;details.push({label:'Fasting Glucose',val:glucose+' mg/dL',status:glucose<90?'Optimal':'Normal (borderline)',risk:glucose<90?'low':'moderate'})}
    else{details.push({label:'Fasting Glucose',val:glucose+' mg/dL',status:glucose>=126?'Diabetic range':'Pre-diabetic range',risk:glucose>=126?'high':'moderate'})}
  }
  if(total===0){alert('Please enter at least one measurement.');return false}
  var pct=Math.round(score/total*100);
  var risk=pct>=80?'low':pct>=50?'moderate':'high';
  var html='<h3>Your Metabolic Health Score</h3>';
  html+='<div class="result-score" style="color:'+_riskColor(risk)+'">'+score+' / '+total+'</div>';
  html+='<div class="result-label">criteria met ('+pct+'%)</div>';
  html+=_bar(pct,_riskColor(risk));
  html+='<p style="margin:16px 0;font-size:15px;color:var(--h-dark-text);">';
  if(score===total) html+='All measured criteria are optimal. A 2022 JACC study found only 6.8% of US adults meet all five criteria.';
  else if(score>=total-1) html+='You meet most criteria. Focus on the flagged marker(s) below to reach full metabolic health.';
  else html+='Multiple markers need attention. A comprehensive metabolic panel with fasting insulin and HOMA-IR can reveal the root cause.';
  html+='</p>';
  for(var i=0;i<details.length;i++){
    var d=details[i];
    html+='<div class="result-item"><div class="ri-label">'+d.label+'</div><div class="ri-value '+_riskClass(d.risk)+'">'+d.val+' — '+d.status+'</div></div>';
  }
  if(total<5) html+='<p style="margin-top:16px;font-size:13px;color:var(--h-gray-text);">You left '+(5-total)+' marker(s) blank. Enter all five for the most complete picture.</p>';
  _show('metabolic-result',html);
  return false;
}

/* ── Insulin Resistance Risk Calculator ── */
function calcIR(e){
  e.preventDefault();
  var insulin=_v('ir-insulin'),glucose=_v('ir-glucose');
  if(isNaN(insulin)||isNaN(glucose)){alert('Fasting insulin and fasting glucose are required.');return false}
  var homa=(insulin*glucose)/405;
  var details=[];
  var irRisk=homa<1.0?'low':homa<1.5?'low':homa<2.5?'moderate':'high';
  details.push({label:'HOMA-IR',val:homa.toFixed(2),status:homa<1.0?'Optimal (<1.0)':homa<1.5?'Low risk (1.0-1.5)':homa<2.5?'Moderate IR (1.5-2.5)':homa<3.0?'Significant IR (2.5-3.0)':'Consistent with metabolic syndrome (>3.0)',risk:irRisk});
  details.push({label:'Fasting Insulin',val:insulin+' μIU/mL',status:insulin<5?'Optimal (<5)':insulin<7?'Good (5-7)':insulin<10?'Mild IR (7-10)':insulin<15?'Moderate IR (10-15)':'Significant IR (>15)',risk:insulin<7?'low':insulin<10?'moderate':'high'});
  details.push({label:'Fasting Glucose',val:glucose+' mg/dL',status:glucose<90?'Optimal':glucose<100?'Normal (borderline)':glucose<126?'Pre-diabetic range':'Diabetic range',risk:glucose<100?'low':glucose<126?'moderate':'high'});
  var trig=_v('ir-trig'),hdl=_v('ir-hdl');
  if(!isNaN(trig)&&!isNaN(hdl)&&hdl>0){
    var ratio=(trig/hdl).toFixed(1);
    details.push({label:'Triglyceride/HDL Ratio',val:ratio,status:ratio<1.5?'Optimal (<1.5)':ratio<2.0?'Good (1.5-2.0)':ratio<3.0?'Elevated (2.0-3.0)':'High IR risk (>3.0)',risk:ratio<2.0?'low':ratio<3.0?'moderate':'high'});
  }
  var waist=_v('ir-waist');
  if(!isNaN(waist)){
    details.push({label:'Waist Circumference',val:waist+'"',status:waist>40?'High risk (>40")':waist>35?'Elevated risk (>35")':'Lower risk',risk:waist>40?'high':waist>35?'moderate':'low'});
  }
  var pct=Math.min(100,Math.round(homa/4*100));
  var html='<h3>Insulin Resistance Assessment</h3>';
  html+='<div class="result-score" style="color:'+_riskColor(irRisk)+'">HOMA-IR: '+homa.toFixed(2)+'</div>';
  html+=_bar(pct,_riskColor(irRisk));
  html+='<p style="margin:12px 0;font-size:15px;">';
  if(homa<1.0) html+='Your HOMA-IR indicates excellent insulin sensitivity. Continue your current health practices.';
  else if(homa<1.5) html+='Mild elevation. Lifestyle optimization (diet, exercise, sleep) can keep this in the optimal range.';
  else if(homa<2.5) html+='Moderate insulin resistance. Targeted dietary and exercise interventions typically improve HOMA-IR within 8-12 weeks.';
  else html+='Significant insulin resistance detected. We recommend reviewing our metabolic health guide and considering a comprehensive lab panel.';
  html+='</p>';
  for(var i=0;i<details.length;i++){
    var d=details[i];
    html+='<div class="result-item"><div class="ri-label">'+d.label+'</div><div class="ri-value '+_riskClass(d.risk)+'">'+d.val+' — '+d.status+'</div></div>';
  }
  _show('ir-result',html);
  return false;
}

/* ── Hormone Symptom Checker ── */
function calcHormone(e){
  e.preventDefault();
  var sex=_sv('hc-sex'),age=_v('hc-age');
  var checks=document.querySelectorAll('#hc-symptoms input[type=checkbox]:checked');
  if(checks.length===0){alert('Please select at least one symptom.');return false}
  var scores={t:0,th:0,c:0,e:0};
  var names={t:'Low Testosterone',th:'Thyroid Dysfunction',c:'Cortisol Dysregulation',e:'Estrogen Imbalance'};
  var colors={t:'#2563eb',th:'#7c3aed',c:'#d97706',e:'#ec4899'};
  checks.forEach(function(cb){
    var h=cb.getAttribute('data-h').split(',');
    h.forEach(function(k){if(scores[k]!==undefined)scores[k]++});
  });
  var maxPossible={t:5,th:5,c:5,e:4};
  var html='<h3>Hormone Symptom Analysis</h3>';
  html+='<p style="margin-bottom:16px;font-size:15px;">Based on '+checks.length+' reported symptom(s), here is the likelihood that each hormonal pathway is involved:</p>';
  var sorted=Object.keys(scores).sort(function(a,b){return scores[b]-scores[a]});
  sorted.forEach(function(k){
    var pct=Math.round(scores[k]/maxPossible[k]*100);
    var risk=pct>=60?'high':pct>=30?'moderate':'low';
    html+='<div style="margin-bottom:16px;">';
    html+='<div style="display:flex;justify-content:space-between;align-items:baseline;"><strong style="color:'+colors[k]+'">'+names[k]+'</strong><span class="'+_riskClass(risk)+'" style="font-weight:600">'+scores[k]+'/'+maxPossible[k]+' symptoms</span></div>';
    html+=_bar(pct,colors[k]);
    html+='</div>';
  });
  html+='<div style="padding:16px;background:var(--h-gray-bg);border-radius:6px;margin-top:16px;">';
  html+='<strong>Recommended Lab Panel:</strong><ul style="margin:8px 0 0 20px;font-size:14px;">';
  if(scores.t>=2) html+='<li>Total testosterone, free testosterone, SHBG, LH, FSH'+(sex==='male'?', estradiol, prolactin':'')+'</li>';
  if(scores.th>=2) html+='<li>TSH, free T3, free T4, reverse T3, TPO antibodies</li>';
  if(scores.c>=2) html+='<li>AM cortisol (serum) or 4-point salivary cortisol, DHEA-S</li>';
  if(scores.e>=2) html+='<li>Estradiol, progesterone'+(sex==='female'?' (cycle day 21 if premenopausal)':'')+', SHBG</li>';
  if(scores.t<2&&scores.th<2&&scores.c<2&&scores.e<2) html+='<li>Comprehensive hormone panel (few strong symptom clusters — broad testing recommended)</li>';
  html+='</ul></div>';
  _show('hormone-result',html);
  return false;
}

/* ── Sleep Recovery Score ── */
function calcSleep(e){
  e.preventDefault();
  var hours=_v('sl-hours');
  if(isNaN(hours)){alert('Please enter your average sleep hours.');return false}
  var quality=parseInt(_sv('sl-quality')),latency=parseInt(_sv('sl-latency')),wakeups=parseInt(_sv('sl-wakeups')),
      daytime=parseInt(_sv('sl-daytime')),snore=parseInt(_sv('sl-snore')),refresh=parseInt(_sv('sl-refresh'));
  var durationScore=hours>=7&&hours<=9?3:hours>=6?2:hours>=5?1:0;
  var raw=durationScore+quality+latency+wakeups+daytime+snore+refresh;
  var maxScore=21;
  var pct=Math.round(raw/maxScore*100);
  var risk=pct>=75?'low':pct>=50?'moderate':'high';
  var html='<h3>Sleep Recovery Score</h3>';
  html+='<div class="result-score" style="color:'+_riskColor(risk)+'">'+pct+'<span style="font-size:20px;color:var(--h-gray-text)"> / 100</span></div>';
  html+='<div class="result-label">'+(pct>=75?'Good recovery — room for optimization':pct>=50?'Moderate — sleep quality is impacting your recovery':'Poor — sleep is significantly impacting your health')+'</div>';
  html+=_bar(pct,_riskColor(risk));
  var flags=[];
  if(durationScore<2) flags.push('Sleep duration is below the recommended 7-9 hours for adults (AASM guidelines).');
  if(latency<2) flags.push('Taking more than 30 minutes to fall asleep (sleep onset latency) may indicate hyperarousal, anxiety, or circadian disruption.');
  if(wakeups<2) flags.push('Frequent nighttime awakenings fragment sleep architecture, reducing restorative deep sleep and REM.');
  if(snore<2) flags.push('<strong>Snoring with breathing pauses is the hallmark symptom of obstructive sleep apnea (OSA).</strong> Consider a sleep study — OSA affects 15-30% of men and 10-15% of women, and many are undiagnosed.');
  if(refresh<2) flags.push('Not feeling refreshed despite adequate sleep time suggests poor sleep quality — possibly fragmented deep sleep, sleep apnea, or cortisol dysregulation.');
  if(daytime<2) flags.push('Excessive daytime sleepiness (Epworth-style indicator) suggests either insufficient sleep quality or an underlying sleep disorder.');
  if(flags.length>0){
    html+='<div style="margin-top:20px;"><strong>Key Findings:</strong><ul style="margin:8px 0 0 20px;font-size:14px;line-height:1.6;">';
    flags.forEach(function(f){html+='<li style="margin-bottom:8px;">'+f+'</li>'});
    html+='</ul></div>';
  }
  if(pct<60){
    html+='<div style="padding:16px;background:var(--h-gray-bg);border-radius:6px;margin-top:16px;"><strong>Recommended Testing:</strong><ul style="margin:8px 0 0 20px;font-size:14px;"><li>4-point salivary cortisol (assess cortisol rhythm)</li><li>Thyroid panel (TSH, free T3, free T4)</li><li>Iron/ferritin (ferritin below 50 impairs sleep quality)</li><li>Sleep study referral if snoring/apnea symptoms present</li></ul></div>';
  }
  _show('sleep-result',html);
  return false;
}

