    why: 'PT-141 is the only peptide that specifically targets sexual function centrally — via melanocortin receptors in the brain, not blood vessels like PDE5 inhibitors (Viagra/Cialis). This means it works for both men and women, and addresses desire/arousal rather than just the mechanical response. FDA-approved for HSDD in premenopausal women (marketed as Vyleesi); used off-label in men for libido and erectile dysfunction.'
  }
};

function pfGetVal(name){ var els=document.querySelectorAll('[name='+name+']:checked'); return els.length>0?els[0].value:null; }
function pfGetChecks(name){ var out=[]; document.querySelectorAll('[name='+name+']:checked').forEach(function(e){out.push(e.value)}); return out; }

function pfNext(step){
  var vals = {0:'goal',1:'age',2:'exp',3:'route',4:'budget',5:'source'};
  if(vals[step]){
    var v=pfGetVal(vals[step]);
    if(!v){ alert('Please make a selection to continue.'); return; }
  }
  document.getElementById('pf-s'+step).classList.remove('active');
  document.getElementById('pf-s'+(step+1)).classList.add('active');
  document.getElementById('pf-d'+step).classList.add('done');
  document.getElementById('pf-d'+(step+1)).classList.add('done');
}
function pfBack(step){
  document.getElementById('pf-s'+step).classList.remove('active');
  document.getElementById('pf-s'+(step-1)).classList.add('active');
  document.getElementById('pf-d'+step).classList.remove('done');
}

function pfCalc(){
  var goal=pfGetVal('goal'), age=pfGetVal('age'), exp=pfGetVal('exp'),
      route=pfGetVal('route'), budget=pfGetVal('budget'),
      source=pfGetVal('source'),
      considers=pfGetChecks('consider');

  var scored=[];
  Object.keys(PF_PEPTIDES).forEach(function(key){
    var p=PF_PEPTIDES[key];
    var s=0;
    // Goal score
    s += (p.scores[goal]||0);
    // Consideration bonuses
    considers.forEach(function(c){ s += (p.considerations[c]||0); });
    // Route penalty
    if(route==='nasal' && p.routePenalty && p.routePenalty.nasal) s -= p.routePenalty.nasal;
    // MK-677 bonus for non-injectable
    if(key==='mk677' && route==='nasal') s += 4;
    if(key==='semax' && route==='nasal') s += 1;
    if(key==='selank' && route==='nasal') s += 1;
    // Age bonus
    if(p.ageBonus && p.ageBonus[age]) s += p.ageBonus[age];
    // Budget filter
    if(p.budgetOk && !p.budgetOk[budget]) s -= 8;
    // Source type: natural-only users avoid synthetic peptides
    if(source==='natural' && !p.natural) s -= 5;
    // Experience: beginners get simpler options
    if(exp==='none'){
      if(key==='tb500' || key==='ipamorelin') s -= 1;
      if(key==='semax' || key==='selank' || key==='mk677') s += 1;
    }
    // WADA competition penalty
    if(considers.indexOf('competition')>-1){
      if(p.considerations.competition) s += p.considerations.competition;
    }
    scored.push({key:key, peptide:p, score:s});
  });

  // Sort descending, take top 3
  scored.sort(function(a,b){return b.score-a.score});
  var top=scored.slice(0,3);

  var rankLabels=['#1 Best Match', '#2 Strong Match', '#3 Consider'];
  var rankColors=['var(--h-teal)', '#2563eb', '#7c3aed'];
  var goalLabels={healing:'injury healing & tissue repair',muscle:'muscle growth & body composition',cognitive:'cognitive performance & focus',longevity:'longevity & anti-aging',weight:'weight & fat loss',anxiety:'stress, anxiety & sleep',sexual:'sexual stamina & libido'};

  var html='<h3 style="font-family:var(--font-serif);font-size:22px;color:var(--h-navy);margin-bottom:4px;">Your Peptide Recommendations</h3>';
  html+='<p style="font-size:14px;color:var(--h-gray-text);margin-bottom:20px;">Based on your goal: <strong>'+goalLabels[goal]+'</strong></p>';

  top.forEach(function(item,i){
    var p=item.peptide;
    html+='<div class="pf-card">';
    html+='<div class="pf-card-rank" style="color:'+rankColors[i]+'">'+rankLabels[i]+'</div>';
    html+='<div class="pf-card-name">'+p.name+'</div>';
    p.tags.forEach(function(t){ html+='<span class="pf-card-tag">'+t+'</span>'; });
    html+='<div class="pf-card-why">'+p.why+'</div>';
    html+='<div class="pf-card-protocol"><strong>Suggested starting protocol:</strong><br>'+p.protocol+'</div>';
    html+='<a class="pf-card-link" href="'+p.url+'">Read the full '+p.name+' guide →</a>';
    html+='</div>';
  });

  // Wolverine stack suggestion
  var topKeys=top.map(function(t){return t.key});
  if(goal==='healing' || considers.indexOf('tendon')>-1){
    if(topKeys.indexOf('bpc157')>-1 || topKeys.indexOf('tb500')>-1){
      html+='<div style="padding:16px;background:#f0fdf9;border:1.5px solid var(--h-teal);border-radius:8px;margin-top:4px;">';
      html+='<strong style="color:var(--h-teal)">💡 Stack Suggestion: The Wolverine Stack</strong>';
      html+='<p style="font-size:14px;margin-top:8px;line-height:1.6;">For maximum healing results, consider combining BPC-157 + TB-500. BPC-157 handles local repair signaling; TB-500 provides systemic angiogenesis support. Together they address complementary aspects of tissue repair. <a href="/compare/bpc-157-vs-tb-500" style="color:var(--h-teal);font-weight:600;">See the full comparison →</a></p></div>';
    }
  }

  if(considers.indexOf('competition')>-1){
    html+='<div style="padding:14px 16px;background:#fff7ed;border:1.5px solid #d97706;border-radius:8px;margin-top:12px;">';
    html+='<strong style="color:#d97706;">⚠️ Competitive Athlete Note</strong>';
    html+='<p style="font-size:13px;margin-top:6px;line-height:1.5;">Several peptides are prohibited by WADA and most sports governing bodies. Verify the status of any peptide with your sport\'s governing body before use. Cognitive peptides (semax, selank) and some longevity peptides (epithalon) are generally not on WADA\'s prohibited list, but confirm for your specific sport.</p></div>';
  }

  html+='<div class="pf-disclaimer">This tool provides educational information only. Peptides carry regulatory and safety considerations that vary by compound, country, and individual health status. Consult a licensed physician before using any peptide therapeutically. <a href="/faq/are-peptides-legal" style="color:var(--h-teal);">Learn about peptide legality →</a></div>';

  var qz=document.getElementById('pf-quiz'); qz.style.display='none';
  _show('pf-result', html);
}

/* ── Energy Optimization Assessment ── */
function calcEnergy(e){
  e.preventDefault();
  var morning=parseInt(_sv('ea-morning')),afternoon=parseInt(_sv('ea-afternoon')),
      exercise=parseInt(_sv('ea-exercise')),mental=parseInt(_sv('ea-mental')),
      sleep=parseInt(_sv('ea-sleep')),stress=parseInt(_sv('ea-stress'));
  var domains={
    metabolic:{score:(morning+afternoon)/2,label:'Metabolic Energy',desc:'Blood sugar regulation, mitochondrial function, body composition'},
    hormonal:{score:(exercise+mental)/2,label:'Hormonal Health',desc:'Testosterone, thyroid, cortisol, recovery hormones'},
    recovery:{score:(sleep+stress)/2,label:'Recovery Quality',desc:'Sleep architecture, stress response, autonomic balance'}
  };
  var total=morning+afternoon+exercise+mental+sleep+stress;
  var pct=Math.round(total/30*100);
  var risk=pct>=70?'low':pct>=45?'moderate':'high';
  var html='<h3>Energy Optimization Score</h3>';
  html+='<div class="result-score" style="color:'+_riskColor(risk)+'">'+pct+'<span style="font-size:20px;color:var(--h-gray-text)"> / 100</span></div>';
  html+=_bar(pct,_riskColor(risk));
  html+='<div style="margin-top:20px;">';
  var dkeys=['metabolic','hormonal','recovery'];
  var dcolors=['#059669','#2563eb','#7c3aed'];
  dkeys.forEach(function(k,i){
    var d=domains[k];
    var dpct=Math.round(d.score/5*100);
    var dr=dpct>=60?'low':dpct>=40?'moderate':'high';
    html+='<div style="margin-bottom:16px;">';
    html+='<div style="display:flex;justify-content:space-between;"><strong style="color:'+dcolors[i]+'">'+d.label+'</strong><span class="'+_riskClass(dr)+'" style="font-weight:600">'+d.score.toFixed(1)+' / 5.0</span></div>';
    html+='<div class="result-bar"><div class="result-bar-fill" style="width:'+dpct+'%;background:'+dcolors[i]+'"></div></div>';
    html+='<div style="font-size:12px;color:var(--h-gray-text);">'+d.desc+'</div>';
    html+='</div>';
  });
  html+='</div>';
  var weakest=dkeys.reduce(function(a,b){return domains[a].score<domains[b].score?a:b});
  var recs={
    metabolic:'Your metabolic energy domain scored lowest. This may indicate blood sugar dysregulation, insulin resistance, or suboptimal body composition. Recommended labs: fasting insulin, HOMA-IR, HbA1c, lipid panel, hs-CRP.',
    hormonal:'Your hormonal health domain scored lowest. This may indicate testosterone deficiency, thyroid dysfunction, or cortisol dysregulation. Recommended labs: total and free testosterone, TSH/free T3/free T4, AM cortisol, DHEA-S.',
    recovery:'Your recovery domain scored lowest. This may indicate poor sleep quality, chronic stress, or autonomic dysfunction. Recommended: 4-point salivary cortisol, iron/ferritin, sleep study if snoring is present, HRV tracking.'
  };
  html+='<div style="padding:16px;background:var(--h-gray-bg);border-radius:6px;margin-top:16px;"><strong>Primary Focus Area:</strong><p style="margin-top:8px;font-size:14px;line-height:1.6;">'+recs[weakest]+'</p></div>';
  _show('energy-result',html);
  return false;
}
</script>
