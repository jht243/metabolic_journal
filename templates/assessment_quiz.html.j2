{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .quiz-wrapper { max-width: 680px; margin: 0 auto; padding: 40px 24px 64px; }
  .quiz-header { text-align: center; margin-bottom: 8px; }
  .quiz-header h1 { font-family: var(--font-serif); font-size: 28px; color: var(--h-navy); margin-bottom: 6px; }
  .quiz-header p { color: var(--h-gray-text); font-size: 15px; }

  .progress-wrap { margin: 24px 0 32px; }
  .progress-labels { display: flex; justify-content: space-between; margin-bottom: 8px; }
  .progress-label { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--h-gray-text); transition: color 0.2s; }
  .progress-label.active { color: var(--h-teal); }
  .progress-label.done { color: var(--h-navy); }
  .progress-track { background: var(--h-gray-light); height: 6px; border-radius: 3px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--h-teal); border-radius: 3px; transition: width 0.35s ease; }

  .step { display: none; }
  .step.active { display: block; }
  .step h2 { font-family: var(--font-serif); font-size: 22px; color: var(--h-navy); margin-bottom: 4px; }
  .step .step-desc { color: var(--h-gray-text); font-size: 14.5px; margin-bottom: 24px; line-height: 1.5; }

  .field { margin-bottom: 20px; }
  .field > label { display: block; font-weight: 600; font-size: 14px; color: var(--h-navy); margin-bottom: 8px; }
  .field input[type="number"], .field select, .field textarea {
    width: 100%; padding: 10px 14px; border: 1px solid var(--h-gray-light);
    border-radius: 6px; font-size: 15px; color: var(--h-dark-text); background: white;
    font-family: var(--font-sans);
  }
  .field input:focus, .field select:focus, .field textarea:focus { outline: none; border-color: var(--h-teal); box-shadow: 0 0 0 3px rgba(13,148,136,0.08); }
  .field textarea { resize: vertical; min-height: 70px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media(max-width:520px){ .field-row { grid-template-columns: 1fr; } }

  .pill-group { display: flex; flex-wrap: wrap; gap: 8px; }
  .pill-group label {
    display: inline-flex; align-items: center; padding: 9px 18px;
    background: white; border: 1.5px solid var(--h-gray-light); border-radius: 100px;
    font-size: 14px; font-weight: 500; cursor: pointer; user-select: none;
    transition: all 0.15s;
  }
  .pill-group label:hover { border-color: var(--h-teal); background: rgba(13,148,136,0.03); }
  .pill-group input { display: none; }
  .pill-group label:has(input:checked) { background: var(--h-teal); border-color: var(--h-teal); color: white; }

  .radio-pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .radio-pills label {
    display: inline-flex; padding: 9px 18px;
    background: white; border: 1.5px solid var(--h-gray-light); border-radius: 100px;
    font-size: 14px; font-weight: 500; cursor: pointer; user-select: none;
    transition: all 0.15s;
  }
  .radio-pills label:hover { border-color: var(--h-teal); }
  .radio-pills input { display: none; }
  .radio-pills label:has(input:checked) { background: var(--h-teal); border-color: var(--h-teal); color: white; }

  .symptom-category { margin-bottom: 20px; }
  .symptom-category > .cat-label { font-size: 13px; font-weight: 700; color: var(--h-gray-text); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 8px; }

  .conditional-section { display: none; }
  .conditional-section.visible { display: block; }

  .field-hint { font-size: 12.5px; color: var(--h-gray-text); margin-top: 4px; line-height: 1.4; }

  .family-history-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  @media(max-width:520px){ .family-history-grid { grid-template-columns: 1fr; } }

  .supplement-note { background: rgba(13,148,136,0.05); border: 1px solid rgba(13,148,136,0.15); border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-size: 13px; color: var(--h-dark-text); line-height: 1.5; }

  .blood-work-info { background: var(--h-gray-bg); border-radius: 8px; padding: 16px 20px; margin-top: 12px; }
  .blood-work-info p { font-size: 13.5px; color: var(--h-dark-text); line-height: 1.5; margin: 0 0 8px; }
  .blood-work-info p:last-child { margin-bottom: 0; }
  .blood-work-info strong { color: var(--h-navy); }

  .nav-buttons { display: flex; justify-content: space-between; margin-top: 32px; padding-top: 20px; border-top: 1px solid var(--h-gray-light); }
  .btn-back-q { background: none; border: 0; font-size: 15px; color: var(--h-gray-text); cursor: pointer; font-weight: 600; padding: 12px 0; }
  .btn-back-q:hover { color: var(--h-dark-text); }

  /* Results */
  .results-section { display: none; }
  .results-section.active { display: block; }
  .score-hero { text-align: center; padding: 32px 0 24px; }
  .score-number { font-size: 64px; font-weight: 700; line-height: 1; }
  .score-subtitle { font-size: 16px; color: var(--h-gray-text); margin-top: 4px; }
  .domain-card { background: var(--h-gray-bg); border-radius: 8px; padding: 20px 24px; margin-bottom: 12px; }
  .domain-card .dc-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
  .domain-card .dc-name { font-weight: 700; font-size: 15px; }
  .domain-card .dc-score { font-weight: 700; font-size: 15px; }
  .domain-bar { height: 8px; background: #e5e7eb; border-radius: 4px; overflow: hidden; }
  .domain-bar-fill { height: 100%; border-radius: 4px; transition: width 0.6s ease; }
  .domain-card .dc-detail { font-size: 13px; color: var(--h-gray-text); margin-top: 8px; line-height: 1.5; }
  .rec-section { margin-top: 28px; }
  .rec-section h3 { font-family: var(--font-serif); font-size: 18px; color: var(--h-navy); margin-bottom: 12px; }
  .rec-list { list-style: none; padding: 0; }
  .rec-list li { padding: 12px 0; border-bottom: 1px solid var(--h-gray-light); font-size: 14px; line-height: 1.5; display: flex; gap: 10px; }
  .rec-list li:last-child { border-bottom: 0; }
  .rec-icon { color: var(--h-teal); font-weight: 700; flex-shrink: 0; }
  .rec-links { margin-top: 28px; }
  .rec-links h3 { font-family: var(--font-serif); font-size: 18px; color: var(--h-navy); margin-bottom: 12px; }
  .rec-link-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media(max-width:520px){ .rec-link-grid { grid-template-columns: 1fr; } }
  .rec-link-card { display: block; padding: 14px 18px; background: white; border: 1px solid var(--h-gray-light); border-radius: 8px; text-decoration: none; transition: border-color 0.15s; }
  .rec-link-card:hover { border-color: var(--h-teal); }
  .rec-link-card .rlc-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--h-teal); }
  .rec-link-card .rlc-title { font-size: 14px; font-weight: 600; color: var(--h-navy); margin-top: 4px; }
  .specialist-cta {
    display: none;
    text-align: center;
    padding: 24px 20px;
    margin-top: 28px;
    background: var(--h-gray-bg);
    border: 1px solid var(--h-gray-light);
    border-radius: 8px;
  }
  .specialist-cta.active { display: block; }
  .specialist-cta h3 { font-family: var(--font-serif); font-size: 18px; color: var(--h-navy); margin-bottom: 8px; }
  .specialist-cta p { font-size: 14px; color: var(--h-gray-text); max-width: 460px; margin: 0 auto 14px; line-height: 1.5; }

  .supp-section { margin-top: 28px; }
  .supp-section h3 { font-family: var(--font-serif); font-size: 18px; color: var(--h-navy); margin-bottom: 12px; }
  .supp-card { background: white; border: 1px solid var(--h-gray-light); border-radius: 8px; padding: 16px 20px; margin-bottom: 10px; }
  .supp-card .supp-name { font-weight: 700; font-size: 14px; color: var(--h-navy); }
  .supp-card .supp-reason { font-size: 13px; color: var(--h-gray-text); margin-top: 4px; line-height: 1.4; }
  .supp-card .supp-form { font-size: 12px; color: var(--h-teal); font-weight: 600; margin-top: 6px; }
  .trust-badges { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin-top: 16px; padding: 16px 20px; background: rgba(13,148,136,0.04); border: 1px solid rgba(13,148,136,0.12); border-radius: 8px; }
  .trust-badge { display: flex; align-items: center; gap: 6px; font-size: 12.5px; font-weight: 600; color: var(--h-navy); }
  .trust-badge .badge-icon { color: var(--h-teal); font-size: 16px; }
  .trust-detail { font-size: 12px; color: var(--h-gray-text); margin-top: 10px; line-height: 1.5; }
</style>
{% endblock %}

{% block content %}
<div class="quiz-wrapper">
  <div class="quiz-header">
    <h1>Health Assessment</h1>
    <p>5 quick sections. Get personalized insights instantly.</p>
  </div>

  <div class="progress-wrap">
    <div class="progress-labels" id="progressLabels">
      <span class="progress-label active" data-s="0">Basics</span>
      <span class="progress-label" data-s="1">Symptoms</span>
      <span class="progress-label" data-s="2">History</span>
      <span class="progress-label" data-s="3">Lifestyle</span>
      <span class="progress-label" data-s="4">Goals</span>
    </div>
    <div class="progress-track"><div class="progress-fill" id="progressBar" style="width:20%"></div></div>
  </div>

  <!-- ===== Step 0: About You ===== -->
  <div class="step active" data-s="0">
    <h2>About You</h2>
    <p class="step-desc">Basic info to personalize your results.</p>
    <div class="field-row">
      <div class="field"><label>Age</label><input type="number" id="q-age" min="13" max="100" placeholder="e.g. 38"></div>
      <div class="field"><label>Biological Sex</label>
        <select id="q-sex"><option value="">Select…</option><option value="male">Male</option><option value="female">Female</option></select>
      </div>
    </div>
    <div class="field-row">
      <div class="field"><label>Height (inches)</label><input type="number" id="q-height" placeholder="e.g. 70"></div>
      <div class="field"><label>Weight (lbs)</label><input type="number" id="q-weight" placeholder="e.g. 180"></div>
    </div>
  </div>

  <!-- ===== Step 1: Symptoms (expanded, age/sex conditional) ===== -->
  <div class="step" data-s="1">
    <h2>Symptoms</h2>
    <p class="step-desc">Select everything you experience regularly. Sections are personalized based on your age and sex.</p>

    <div class="symptom-category">
      <div class="cat-label">Energy & Fatigue</div>
      <div class="pill-group" data-domain="metabolic">
        <label><input type="checkbox" value="Persistent fatigue"><span>Persistent fatigue</span></label>
        <label><input type="checkbox" value="Post-meal crashes"><span>Post-meal energy crashes</span></label>
        <label><input type="checkbox" value="Afternoon slump"><span>Afternoon slump</span></label>
        <label><input type="checkbox" value="Need caffeine"><span>Need caffeine to function</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Weight & Body Composition</div>
      <div class="pill-group" data-domain="metabolic">
        <label><input type="checkbox" value="Unexplained weight gain"><span>Unexplained weight gain</span></label>
        <label><input type="checkbox" value="Can't lose weight"><span>Can't lose weight</span></label>
        <label><input type="checkbox" value="Belly fat"><span>Belly fat accumulation</span></label>
        <label><input type="checkbox" value="Sugar cravings"><span>Sugar / carb cravings</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Cardiovascular</div>
      <div class="pill-group" data-domain="cardiovascular">
        <label><input type="checkbox" value="Chest tightness"><span>Chest tightness or pain</span></label>
        <label><input type="checkbox" value="Shortness of breath"><span>Shortness of breath</span></label>
        <label><input type="checkbox" value="Heart palpitations"><span>Heart palpitations</span></label>
        <label><input type="checkbox" value="High blood pressure"><span>High blood pressure</span></label>
        <label><input type="checkbox" value="Swollen legs"><span>Swollen legs / ankles</span></label>
        <label><input type="checkbox" value="Dizziness"><span>Dizziness or lightheadedness</span></label>
        <label><input type="checkbox" value="Exercise intolerance"><span>Poor exercise tolerance</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Hormonal</div>
      <div class="pill-group" data-domain="hormonal">
        <label><input type="checkbox" value="Low sex drive"><span>Low sex drive</span></label>
        <label><input type="checkbox" value="Brain fog"><span>Brain fog</span></label>
        <label><input type="checkbox" value="Mood swings"><span>Mood swings</span></label>
        <label><input type="checkbox" value="Hair thinning"><span>Hair thinning / loss</span></label>
        <label><input type="checkbox" value="Cold intolerance"><span>Cold intolerance</span></label>
        <label><input type="checkbox" value="Dry skin"><span>Dry skin</span></label>
      </div>
    </div>

    <!-- Menopause: shown for females age 40+ -->
    <div class="symptom-category conditional-section" id="menopause-section">
      <div class="cat-label">Menopause & Perimenopause</div>
      <div class="pill-group" data-domain="hormonal">
        <label><input type="checkbox" value="Hot flashes"><span>Hot flashes</span></label>
        <label><input type="checkbox" value="Night sweats (hormonal)"><span>Night sweats</span></label>
        <label><input type="checkbox" value="Irregular periods"><span>Irregular periods</span></label>
        <label><input type="checkbox" value="Periods stopped"><span>Periods have stopped</span></label>
        <label><input type="checkbox" value="Vaginal dryness"><span>Vaginal dryness</span></label>
        <label><input type="checkbox" value="Urinary urgency"><span>Urinary urgency / frequency</span></label>
        <label><input type="checkbox" value="Weight redistribution"><span>Weight shifting to midsection</span></label>
        <label><input type="checkbox" value="Memory changes"><span>Memory or concentration changes</span></label>
        <label><input type="checkbox" value="Joint stiffness"><span>Joint stiffness or aches</span></label>
        <label><input type="checkbox" value="Sleep disruption hormonal"><span>Sleep disruption</span></label>
      </div>
    </div>

    <!-- Female general: shown for females under 40 -->
    <div class="symptom-category conditional-section" id="female-general-section">
      <div class="cat-label">Menstrual & Reproductive</div>
      <div class="pill-group" data-domain="hormonal">
        <label><input type="checkbox" value="Irregular periods"><span>Irregular periods</span></label>
        <label><input type="checkbox" value="Heavy periods"><span>Heavy or painful periods</span></label>
        <label><input type="checkbox" value="Hot flashes"><span>Hot flashes</span></label>
        <label><input type="checkbox" value="PMS symptoms"><span>Severe PMS symptoms</span></label>
        <label><input type="checkbox" value="Acne hormonal"><span>Hormonal acne</span></label>
      </div>
    </div>

    <!-- Male Health: shown for males age 40+ -->
    <div class="symptom-category conditional-section" id="male-section">
      <div class="cat-label">Male Health</div>
      <div class="pill-group" data-domain="hormonal">
        <label><input type="checkbox" value="Erectile difficulty"><span>Erectile difficulty</span></label>
        <label><input type="checkbox" value="Frequent urination"><span>Frequent urination</span></label>
        <label><input type="checkbox" value="Weak urine stream"><span>Weak urine stream</span></label>
        <label><input type="checkbox" value="Night urination"><span>Getting up at night to urinate</span></label>
        <label><input type="checkbox" value="Loss of muscle mass"><span>Loss of muscle mass</span></label>
        <label><input type="checkbox" value="Gynecomastia"><span>Breast tissue enlargement</span></label>
        <label><input type="checkbox" value="Low motivation"><span>Loss of drive / motivation</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Bone & Joint Health</div>
      <div class="pill-group" data-domain="bone">
        <label><input type="checkbox" value="Joint pain"><span>Joint pain or stiffness</span></label>
        <label><input type="checkbox" value="Back pain"><span>Chronic back pain</span></label>
        <label><input type="checkbox" value="Fracture history"><span>History of fractures</span></label>
        <label><input type="checkbox" value="Height loss"><span>Loss of height</span></label>
        <label><input type="checkbox" value="Weak grip"><span>Weak grip strength</span></label>
        <label><input type="checkbox" value="Muscle cramps"><span>Frequent muscle cramps</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Digestive</div>
      <div class="pill-group" data-domain="metabolic">
        <label><input type="checkbox" value="Bloating"><span>Bloating</span></label>
        <label><input type="checkbox" value="Acid reflux"><span>Acid reflux / heartburn</span></label>
        <label><input type="checkbox" value="Constipation"><span>Constipation</span></label>
        <label><input type="checkbox" value="Food sensitivities"><span>Food sensitivities</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Sleep & Recovery</div>
      <div class="pill-group" data-domain="recovery">
        <label><input type="checkbox" value="Trouble falling asleep"><span>Trouble falling asleep</span></label>
        <label><input type="checkbox" value="Night wakeups"><span>Frequent night wakeups</span></label>
        <label><input type="checkbox" value="Unrefreshed"><span>Wake up unrefreshed</span></label>
        <label><input type="checkbox" value="Night sweats"><span>Night sweats</span></label>
        <label><input type="checkbox" value="Snoring"><span>Snoring / breathing pauses</span></label>
        <label><input type="checkbox" value="Frequent colds"><span>Frequent colds</span></label>
      </div>
    </div>

    <div class="symptom-category">
      <div class="cat-label">Stress & Mental</div>
      <div class="pill-group" data-domain="recovery">
        <label><input type="checkbox" value="Anxiety"><span>Anxiety / irritability</span></label>
        <label><input type="checkbox" value="Wired but tired"><span>Wired but tired at night</span></label>
        <label><input type="checkbox" value="Low mood"><span>Low mood / depression</span></label>
        <label><input type="checkbox" value="Poor stress tolerance"><span>Poor stress tolerance</span></label>
      </div>
    </div>

    <!-- Teen/Young Adult: shown for ages 13-24 -->
    <div class="symptom-category conditional-section" id="teen-section">
      <div class="cat-label">Young Adult Concerns</div>
      <div class="pill-group" data-domain="recovery">
        <label><input type="checkbox" value="Skipping meals"><span>Frequently skipping meals</span></label>
        <label><input type="checkbox" value="Restrictive eating"><span>Restrictive eating patterns</span></label>
        <label><input type="checkbox" value="Substance use"><span>Substance or drug use</span></label>
        <label><input type="checkbox" value="Vaping"><span>Vaping or smoking</span></label>
        <label><input type="checkbox" value="Energy drink dependence"><span>Heavy energy drink use</span></label>
        <label><input type="checkbox" value="Screen sleep issues"><span>Screens disrupting sleep</span></label>
        <label><input type="checkbox" value="Concentration issues"><span>Difficulty concentrating</span></label>
        <label><input type="checkbox" value="Social withdrawal"><span>Social withdrawal</span></label>
      </div>
    </div>
  </div>

  <!-- ===== Step 2: Health History (expanded) ===== -->
  <div class="step" data-s="2">
    <h2>Health History</h2>
    <p class="step-desc">Your past and current health context helps us give better recommendations.</p>

    <div class="field"><label>Any diagnosed conditions?</label>
      <textarea id="q-conditions" placeholder="e.g. hypothyroidism, pre-diabetes, PCOS, high cholesterol, or none" rows="2"></textarea>
    </div>

    <div class="field"><label>Do you think you may have any undiagnosed issues?</label>
      <textarea id="q-undiagnosed" placeholder="e.g. I suspect thyroid problems, I think my hormones are off, possible sleep apnea, or none" rows="2"></textarea>
    </div>

    <div class="field"><label>Current prescription medications</label>
      <textarea id="q-medications" placeholder="List any prescription medications you take regularly, including dosage if known" rows="2"></textarea>
    </div>

    <div class="field"><label>Current supplements</label>
      <div class="supplement-note">
        Please use the full ingredient name rather than brand names. For example, write <strong>"magnesium glycinate 400mg"</strong> instead of "Calm Magnesium," or <strong>"vitamin D3 5000 IU"</strong> instead of "Bone Builder." Brand names like "Bone Up" or "Heart Defender" make it impossible for us to know what's actually inside.
      </div>
      <textarea id="q-supplements" placeholder="e.g. magnesium glycinate 400mg, vitamin D3 5000 IU, omega-3 fish oil 2g, or none" rows="3"></textarea>
    </div>

    <div class="field"><label>Family history</label>
      <p class="field-hint">Select any conditions that run in your immediate family (parents, siblings, grandparents).</p>
      <div class="pill-group family-history-grid" id="family-history-group">
        <label><input type="checkbox" value="Heart disease"><span>Heart disease</span></label>
        <label><input type="checkbox" value="Diabetes"><span>Diabetes (Type 2)</span></label>
        <label><input type="checkbox" value="Osteoporosis"><span>Osteoporosis</span></label>
        <label><input type="checkbox" value="Cancer"><span>Cancer</span></label>
        <label><input type="checkbox" value="High blood pressure family"><span>High blood pressure</span></label>
        <label><input type="checkbox" value="High cholesterol family"><span>High cholesterol</span></label>
        <label><input type="checkbox" value="Stroke"><span>Stroke</span></label>
        <label><input type="checkbox" value="Thyroid disease"><span>Thyroid disease</span></label>
        <label><input type="checkbox" value="Autoimmune"><span>Autoimmune conditions</span></label>
        <label><input type="checkbox" value="Alzheimers"><span>Alzheimer's / dementia</span></label>
        <label><input type="checkbox" value="Obesity family"><span>Obesity</span></label>
        <label><input type="checkbox" value="Mental health family"><span>Depression / anxiety</span></label>
      </div>
    </div>

    <div class="field"><label>Recent blood work</label>
      <div class="radio-pills">
        <label><input type="radio" name="labs" value="none"><span>None</span></label>
        <label><input type="radio" name="labs" value="6mo"><span>Within 6 months</span></label>
        <label><input type="radio" name="labs" value="1yr"><span>Within a year</span></label>
        <label><input type="radio" name="labs" value="older"><span>Over a year ago</span></label>
      </div>
      <div class="blood-work-info">
        <p><strong>Most standard blood tests only scratch the surface.</strong> A typical panel checks basic CBC, glucose, and maybe a lipid panel — but misses critical markers that reveal early risk factors.</p>
        <p>We can provide a much more comprehensive panel that includes fasting insulin, HbA1c, full thyroid (TSH, free T3, free T4), hormones, inflammatory markers, and more — giving you a complete picture of your metabolic health.</p>
        <p>If you have recent lab results, we can analyze what you already have, identify what's missing, and recommend additional tests you may need.</p>
      </div>
    </div>
  </div>

  <!-- ===== Step 3: Lifestyle ===== -->
  <div class="step" data-s="3">
    <h2>Lifestyle</h2>
    <p class="step-desc">Daily habits that affect your metabolic and hormonal health.</p>

    <div class="field"><label>Diet pattern</label>
      <div class="radio-pills">
        <label><input type="radio" name="diet" value="Standard"><span>Standard American</span></label>
        <label><input type="radio" name="diet" value="Mediterranean"><span>Mediterranean</span></label>
        <label><input type="radio" name="diet" value="Low-carb"><span>Low-carb / keto</span></label>
        <label><input type="radio" name="diet" value="Plant-based"><span>Plant-based</span></label>
        <label><input type="radio" name="diet" value="IF"><span>Intermittent fasting</span></label>
        <label><input type="radio" name="diet" value="None"><span>No specific diet</span></label>
      </div>
    </div>

    <div class="field"><label>Exercise frequency</label>
      <div class="radio-pills">
        <label><input type="radio" name="exercise" value="0"><span>Sedentary</span></label>
        <label><input type="radio" name="exercise" value="1"><span>1–2x / week</span></label>
        <label><input type="radio" name="exercise" value="2"><span>3–4x / week</span></label>
        <label><input type="radio" name="exercise" value="3"><span>5+ x / week</span></label>
      </div>
    </div>

    <div class="field"><label>Sleep duration</label>
      <div class="radio-pills">
        <label><input type="radio" name="sleep" value="0"><span>Under 5 hours</span></label>
        <label><input type="radio" name="sleep" value="1"><span>5–6 hours</span></label>
        <label><input type="radio" name="sleep" value="2"><span>6–7 hours</span></label>
        <label><input type="radio" name="sleep" value="3"><span>7–8 hours</span></label>
        <label><input type="radio" name="sleep" value="4"><span>8+ hours</span></label>
      </div>
    </div>

    <div class="field"><label>Stress level</label>
      <div class="radio-pills">
        <label><input type="radio" name="stress" value="0"><span>Low</span></label>
        <label><input type="radio" name="stress" value="1"><span>Moderate</span></label>
        <label><input type="radio" name="stress" value="2"><span>High</span></label>
        <label><input type="radio" name="stress" value="3"><span>Very high</span></label>
      </div>
    </div>
  </div>

  <!-- ===== Step 4: Goals (moved to last) ===== -->
  <div class="step" data-s="4">
    <h2>Your Goals</h2>
    <p class="step-desc">Now that you've reviewed your health picture — what matters most to you? Select all that apply.</p>
    <div class="pill-group" id="goals-group">
      <label><input type="checkbox" value="Resolve my symptoms"><span>Resolve the symptoms I selected</span></label>
      <label><input type="checkbox" value="More energy"><span>More energy</span></label>
      <label><input type="checkbox" value="Lose body fat"><span>Lose body fat</span></label>
      <label><input type="checkbox" value="Build muscle"><span>Build muscle</span></label>
      <label><input type="checkbox" value="Better sleep"><span>Better sleep</span></label>
      <label><input type="checkbox" value="Balance hormones"><span>Balance hormones</span></label>
      <label><input type="checkbox" value="Reduce brain fog"><span>Reduce brain fog</span></label>
      <label><input type="checkbox" value="Improve mood"><span>Improve mood</span></label>
      <label><input type="checkbox" value="Increase libido"><span>Increase libido</span></label>
      <label><input type="checkbox" value="Reduce stress"><span>Reduce stress</span></label>
      <label><input type="checkbox" value="Optimize metabolic health"><span>Optimize metabolic health</span></label>
      <label><input type="checkbox" value="Slow aging"><span>Slow aging</span></label>
      <label><input type="checkbox" value="Improve bone health"><span>Improve bone health</span></label>
      <label><input type="checkbox" value="Heart health"><span>Improve heart health</span></label>
      <label><input type="checkbox" value="Get comprehensive blood work"><span>Get comprehensive blood work</span></label>
    </div>
  </div>

  <!-- ===== Results (hidden until submit) ===== -->
  <div class="results-section" id="resultsSection">
    <div class="score-hero">
      <div class="score-number" id="totalScore" style="color:var(--h-teal)">—</div>
      <div class="score-subtitle">Overall Health Optimization Score</div>
    </div>

    <div id="domainCards"></div>

    <div class="rec-section">
      <h3>Recommended Next Steps</h3>
      <ul class="rec-list" id="recList"></ul>
    </div>

    <div class="supp-section" id="suppSection" style="display:none">
      <h3>Supplement Recommendations</h3>
      <p style="font-size:14px; color:var(--h-gray-text); margin-bottom:16px; line-height:1.5;">Based on your symptoms and risk factors, these supplements may support your health goals.</p>
      <div id="suppCards"></div>
      <div class="trust-badges">
        <div class="trust-badge"><span class="badge-icon">✓</span> GMP Certified</div>
        <div class="trust-badge"><span class="badge-icon">✓</span> ISO 17025 Lab Tested</div>
        <div class="trust-badge"><span class="badge-icon">✓</span> Third-Party Verified</div>
      </div>
      <div class="trust-detail">
        We only recommend products that are <strong>GMP certified</strong> (Good Manufacturing Practices) — meaning the manufacturing facility has been audited by a third party and follows strict guidelines for quality, sanitation, and consistency. All products are tested by <strong>ISO 17025-accredited laboratories</strong>, the international standard for technical competence in testing. This means every product is verified for purity, potency, and absence of contaminants like heavy metals. Our supplements are cleaner, purer, and more effective than what you'll find on most store shelves.
      </div>
    </div>

    <div class="specialist-cta" id="specialistCta">
      <h3>A specialist can help interpret these results</h3>
      <p>Your answers suggest this may be worth reviewing with a clinician who works in the relevant specialty.</p>
      <a class="btn-primary" id="specialistCtaLink" href="/book?concern=general&source=assessment-quiz">Book An Appointment With A Specialist →</a>
    </div>

    <div class="rec-links">
      <h3>Recommended Reading</h3>
      <div class="rec-link-grid" id="recLinks"></div>
    </div>

    <div style="text-align:center; margin-top:32px;">
      <a href="/assessment/quiz" class="btn-primary" onclick="location.reload();return false;">Retake Assessment</a>
    </div>
  </div>

  <div class="nav-buttons" id="navButtons">
    <button type="button" class="btn-back-q" id="btnBack" style="visibility:hidden">← Back</button>
    <button type="button" class="btn-primary" id="btnNext">Continue →</button>
  </div>
</div>
{% endblock %}

{% block scripts_extra %}
<script>
(function(){
  var cur=0, total=5;
  var steps=document.querySelectorAll('.step');
  var labels=document.querySelectorAll('.progress-label');
  var bar=document.getElementById('progressBar');
  var btnN=document.getElementById('btnNext');
  var btnB=document.getElementById('btnBack');
  var nav=document.getElementById('navButtons');
  var results=document.getElementById('resultsSection');

  function getAge(){ return parseInt(document.getElementById('q-age').value)||0; }
  function getSex(){ return document.getElementById('q-sex').value; }

  function updateConditionalSections(){
    var age=getAge(), sex=getSex();
    var menopause=document.getElementById('menopause-section');
    var femaleGeneral=document.getElementById('female-general-section');
    var male=document.getElementById('male-section');
    var teen=document.getElementById('teen-section');

    menopause.classList.toggle('visible', sex==='female' && age>=40);
    femaleGeneral.classList.toggle('visible', sex==='female' && age<40);
    male.classList.toggle('visible', sex==='male' && age>=40);
    teen.classList.toggle('visible', age>=13 && age<=24);
  }

  document.getElementById('q-age').addEventListener('change', updateConditionalSections);
  document.getElementById('q-sex').addEventListener('change', updateConditionalSections);

  function show(){
    steps.forEach(function(s,i){s.classList.toggle('active',i===cur)});
    labels.forEach(function(l,i){
      l.classList.remove('active','done');
      if(i===cur)l.classList.add('active');
      else if(i<cur)l.classList.add('done');
    });
    bar.style.width=((cur+1)/total*100)+'%';
    btnB.style.visibility=cur===0?'hidden':'visible';
    btnN.textContent=cur===total-1?'Get My Results':'Continue →';
  }

  var stepNames=['symptoms','health_history','lifestyle','goals'];
  btnN.addEventListener('click',function(){
    if(cur===0) updateConditionalSections();
    if(cur<total-1){
      cur++;show();window.scrollTo({top:0,behavior:'smooth'});
      if(window._ga) window._ga('funnel_step',{funnel_name:'assessment_quiz',step_number:String(cur+1),step_label:stepNames[cur-1]||''});
    }
    else{computeResults();}
  });
  btnB.addEventListener('click',function(){
    if(cur>0){cur--;show();window.scrollTo({top:0,behavior:'smooth'});}
  });

  function checked(sel){
    var out=[];
    document.querySelectorAll(sel).forEach(function(cb){if(cb.checked)out.push(cb.value)});
    return out;
  }
  function radioVal(name){var r=document.querySelector('input[name="'+name+'"]:checked');return r?r.value:'';}

  function computeResults(){
    var age=getAge(), sex=getSex();
    var metabolicSymptoms=0,hormonalSymptoms=0,recoverySymptoms=0,cardioSymptoms=0,boneSymptoms=0;

    document.querySelectorAll('.pill-group[data-domain="metabolic"] input:checked').forEach(function(){metabolicSymptoms++});
    document.querySelectorAll('.pill-group[data-domain="hormonal"] input:checked').forEach(function(){hormonalSymptoms++});
    document.querySelectorAll('.pill-group[data-domain="recovery"] input:checked').forEach(function(){recoverySymptoms++});
    document.querySelectorAll('.pill-group[data-domain="cardiovascular"] input:checked').forEach(function(){cardioSymptoms++});
    document.querySelectorAll('.pill-group[data-domain="bone"] input:checked').forEach(function(){boneSymptoms++});

    var exercise=parseInt(radioVal('exercise'))||0;
    var sleepVal=parseInt(radioVal('sleep'))||0;
    var stressVal=parseInt(radioVal('stress'))||0;

    var familyHistory=checked('#family-history-group input');
    var symptoms=checked('.step[data-s="1"] input[type="checkbox"]');
    var hasCardioFamily=familyHistory.indexOf('Heart disease')!==-1||familyHistory.indexOf('High blood pressure family')!==-1||familyHistory.indexOf('Stroke')!==-1||familyHistory.indexOf('High cholesterol family')!==-1;
    var hasDiabetesFamily=familyHistory.indexOf('Diabetes')!==-1;
    var hasBoneFamily=familyHistory.indexOf('Osteoporosis')!==-1;
    var hasCancerFamily=familyHistory.indexOf('Cancer')!==-1;
    var hasFrequentColds=symptoms.indexOf('Frequent colds')!==-1;

    var metScore=Math.max(0,100-metabolicSymptoms*12-Math.max(0,2-exercise)*8);
    if(hasDiabetesFamily) metScore=Math.max(0,metScore-8);

    var hormScore=Math.max(0,100-hormonalSymptoms*10);

    var recScore=Math.max(0,100-recoverySymptoms*11-(3-Math.min(sleepVal,3))*10-stressVal*8);

    var cardioScore=Math.max(0,100-cardioSymptoms*14);
    if(hasCardioFamily) cardioScore=Math.max(0,cardioScore-10);
    if(age>=50) cardioScore=Math.max(0,cardioScore-5);

    var boneScore=Math.max(0,100-boneSymptoms*15);
    if(hasBoneFamily) boneScore=Math.max(0,boneScore-10);
    if(sex==='female'&&age>=50) boneScore=Math.max(0,boneScore-8);

    var scores=[metScore,hormScore,recScore,cardioScore,boneScore];
    var overall=Math.round(scores.reduce(function(a,b){return a+b},0)/scores.length);

    var domains=[
      {name:'Metabolic Health',score:metScore,color:'#059669',
       detail:metScore>=70?'Your metabolic markers look relatively healthy. Maintain your current habits and consider periodic fasting insulin testing.':
              metScore>=40?'Some metabolic stress signals present. Diet optimization and regular exercise can meaningfully improve these markers within 8–12 weeks.':
              'Multiple metabolic warning signs. We recommend a comprehensive metabolic panel including fasting insulin, HbA1c, and lipid panel.'},
      {name:'Hormonal Health',score:hormScore,color:'#7c3aed',
       detail:hormScore>=70?'Hormonal symptoms are minimal. Annual hormone panel is still recommended, especially after age 35.':
              hormScore>=40?'Moderate hormonal symptom burden. A targeted hormone panel (testosterone, thyroid, cortisol) can identify the root cause.':
              'Significant hormonal symptoms reported. A full hormone panel is strongly recommended — these symptoms are treatable once properly diagnosed.'},
      {name:'Sleep & Recovery',score:recScore,color:'#2563eb',
       detail:recScore>=70?'Your recovery capacity appears solid. Consider HRV tracking to optimize training and stress management.':
              recScore>=40?'Recovery is compromised. Focus on sleep hygiene fundamentals and consider a 4-point salivary cortisol test.':
              'Major recovery deficit. Poor sleep and high stress compound metabolic and hormonal issues. A sleep study may be warranted if snoring is present.'},
      {name:'Cardiovascular Health',score:cardioScore,color:'#dc2626',
       detail:cardioScore>=70?'Cardiovascular risk appears low based on your symptoms. Continue maintaining heart-healthy habits and get regular blood pressure checks.':
              cardioScore>=40?'Some cardiovascular concerns noted. Consider a comprehensive lipid panel, blood pressure monitoring, and discuss with your doctor.':
              'Multiple cardiovascular warning signs. We strongly recommend a cardiac workup including advanced lipid panel, hs-CRP, and possibly a cardiac calcium score.'},
      {name:'Bone & Joint Health',score:boneScore,color:'#ea580c',
       detail:boneScore>=70?'Bone and joint health appears stable. Ensure adequate vitamin D, calcium, and weight-bearing exercise.':
              boneScore>=40?'Some bone and joint concerns. A DEXA scan may be warranted, along with checking vitamin D, calcium, and magnesium levels.':
              'Significant bone and joint symptoms. We recommend a DEXA scan, comprehensive mineral panel, and evaluation for osteoporosis risk factors.'}
    ];

    var scoreColor=overall>=65?'#059669':overall>=40?'#d97706':'#dc2626';
    document.getElementById('totalScore').textContent=overall+'/100';
    document.getElementById('totalScore').style.color=scoreColor;

    var cardsHtml='';
    domains.forEach(function(d){
      var c=d.score>=65?'#059669':d.score>=40?'#d97706':'#dc2626';
      cardsHtml+='<div class="domain-card"><div class="dc-header"><span class="dc-name" style="color:'+d.color+'">'+d.name+'</span><span class="dc-score" style="color:'+c+'">'+d.score+'/100</span></div><div class="domain-bar"><div class="domain-bar-fill" style="width:'+d.score+'%;background:'+d.color+'"></div></div><div class="dc-detail">'+d.detail+'</div></div>';
    });
    document.getElementById('domainCards').innerHTML=cardsHtml;

    var recs=[];
    if(metScore<60){
      recs.push('Get a fasting insulin and HbA1c test — these reveal metabolic issues years before fasting glucose becomes abnormal');
      recs.push('Prioritize 150+ minutes of zone 2 cardio and 2+ strength sessions per week');
    }
    if(hormScore<60){
      recs.push('Request a comprehensive hormone panel: total/free testosterone, TSH, free T3/T4, AM cortisol, DHEA-S');
      if(sex==='female') recs.push('Add estradiol, progesterone, and SHBG to your hormone panel');
    }
    if(recScore<60){
      recs.push('Implement a strict wind-down routine: no screens 60 min before bed, bedroom at 65–68°F, consistent wake time');
      recs.push('Consider a 4-point salivary cortisol test if you feel "wired but tired"');
    }
    if(cardioScore<60){
      recs.push('Get an advanced lipid panel including Lp(a), ApoB, and hs-CRP — standard cholesterol tests miss key risk factors');
      if(age>=45) recs.push('Consider a coronary artery calcium (CAC) score to assess plaque buildup');
    }
    if(boneScore<60){
      recs.push('Request a DEXA scan to measure bone mineral density — especially important for women over 50 and anyone with family history of osteoporosis');
      recs.push('Check your vitamin D, calcium, and magnesium levels — deficiencies are common and directly affect bone strength');
    }
    if(sleepVal<2) recs.push('Your sleep duration is below the 7–9 hour recommendation — this alone can drive weight gain, insulin resistance, and low testosterone');
    if(stressVal>=2) recs.push('High chronic stress elevates cortisol, which directly impairs insulin sensitivity, testosterone, and sleep architecture');
    if(exercise<1) recs.push('Even 3 sessions of 30-minute walks per week significantly improve insulin sensitivity and hormone levels');
    if(hasDiabetesFamily) recs.push('With diabetes in your family history, regular fasting insulin and glucose monitoring is especially important for early detection');
    if(hasCardioFamily) recs.push('Family history of cardiovascular disease increases your risk — proactive screening with advanced lipid markers is recommended');
    if(hasCancerFamily) recs.push('Family history of cancer is worth discussing with your clinician so screening timing, genetics, and lifestyle risk factors can be personalized');
    if(hasFrequentColds) recs.push('Frequent colds can signal immune strain or nutrient gaps — check vitamin D, CBC with differential, zinc status, sleep quality, and chronic stress load');
    if(recs.length===0) recs.push('Your profile looks strong — maintain current habits and retest annually');

    var recHtml='';
    recs.forEach(function(r){recHtml+='<li><span class="rec-icon">→</span><span>'+r+'</span></li>'});
    document.getElementById('recList').innerHTML=recHtml;

    // Supplement recommendations based on symptoms and risk factors
    var supps=[];
    if(metScore<70||hasDiabetesFamily){
      supps.push({name:'Berberine',form:'Berberine HCl 500mg',reason:'Supports healthy blood sugar levels and insulin sensitivity — shown in studies to be as effective as some prescription medications for glucose management.'});
      supps.push({name:'Chromium',form:'Chromium picolinate 200mcg',reason:'Essential trace mineral that helps improve insulin receptor function and glucose metabolism.'});
    }
    if(hormScore<70){
      supps.push({name:'Magnesium',form:'Magnesium glycinate 400mg',reason:'Supports over 300 enzymatic processes including hormone production. Glycinate form is better absorbed and gentler on the stomach than oxide.'});
      supps.push({name:'Vitamin D3 + K2',form:'Vitamin D3 5000 IU + K2 (MK-7) 100mcg',reason:'Most people are deficient. Vitamin D is crucial for hormone production, immune function, and bone health. K2 ensures calcium goes to bones, not arteries.'});
    }
    if(recScore<70){
      supps.push({name:'Magnesium L-Threonate',form:'Magnesium L-threonate 2000mg',reason:'The only form of magnesium shown to cross the blood-brain barrier. Supports sleep quality, relaxation, and cognitive function.'});
      supps.push({name:'L-Theanine',form:'L-Theanine 200mg',reason:'Amino acid found in tea that promotes relaxation without drowsiness. Helps reduce stress and improve sleep onset.'});
    }
    if(hasFrequentColds){
      supps.push({name:'Vitamin D3 + K2',form:'Vitamin D3 5000 IU + K2 (MK-7) 100mcg',reason:'Vitamin D supports innate immune defense and is commonly low. Test 25-OH vitamin D and dose to maintain an optimal range rather than guessing long-term.'});
      supps.push({name:'Zinc',form:'Zinc picolinate 15-30mg',reason:'Zinc supports immune cell signaling and mucosal defenses. Use moderate doses and avoid long-term high-dose zinc without copper monitoring.'});
      supps.push({name:'Vitamin C',form:'Vitamin C 500-1000mg',reason:'Supports antioxidant defenses and immune cell function, especially during periods of high stress, poor sleep, or frequent upper-respiratory infections.'});
    }
    if(cardioScore<70||hasCardioFamily){
      supps.push({name:'Omega-3 Fish Oil',form:'EPA 1000mg + DHA 500mg (triglyceride form)',reason:'Supports heart health, reduces inflammation, and improves lipid markers. Triglyceride form is better absorbed than ethyl ester.'});
      supps.push({name:'CoQ10',form:'Ubiquinol (CoQ10) 200mg',reason:'Essential for heart muscle energy production. Levels decline with age and are further depleted by statin medications.'});
    }
    if(boneScore<70||hasBoneFamily){
      supps.push({name:'Calcium',form:'Calcium citrate 500mg (split doses)',reason:'Citrate form is better absorbed than carbonate, especially in older adults. Split dosing improves absorption.'});
      supps.push({name:'Vitamin D3 + K2',form:'Vitamin D3 5000 IU + K2 (MK-7) 100mcg',reason:'Critical for calcium absorption and bone mineralization. K2 directs calcium into bones and teeth rather than soft tissues.'});
      supps.push({name:'Collagen Peptides',form:'Hydrolyzed collagen peptides 10g',reason:'Supports joint cartilage, bone matrix, and connective tissue. Studies show improvement in joint pain and bone density.'});
    }
    if(age>=13&&age<=24){
      supps.push({name:'Multivitamin',form:'High-quality whole-food multivitamin',reason:'Young adults often have nutritional gaps from inconsistent eating. A comprehensive multivitamin covers baseline micronutrient needs.'});
      supps.push({name:'Iron',form:'Iron bisglycinate 25mg (if deficient)',reason:'Iron deficiency is common in teens and young adults, especially females. Bisglycinate form minimizes digestive side effects. Get tested before supplementing.'});
    }
    // Deduplicate by name
    var seen={}, uniqueSupps=[];
    supps.forEach(function(s){ if(!seen[s.name]){seen[s.name]=true;uniqueSupps.push(s);} });

    if(uniqueSupps.length>0){
      var suppHtml='';
      uniqueSupps.forEach(function(s){
        suppHtml+='<div class="supp-card"><div class="supp-name">'+s.name+'</div><div class="supp-reason">'+s.reason+'</div><div class="supp-form">Recommended form: '+s.form+'</div></div>';
      });
      document.getElementById('suppCards').innerHTML=suppHtml;
      document.getElementById('suppSection').style.display='block';
    }

    if(window._ga) window._ga('tool_used',{tool_name:'assessment_quiz',overall_score:overall.toString(),weakest_domain:domains.reduce(function(a,b){return a.score<=b.score?a:b}).name});

    var lowest=domains.reduce(function(a,b){return a.score<=b.score?a:b});
    var specialistConcern=lowest.name==='Metabolic Health'?'metabolic':lowest.name==='Hormonal Health'?'hormones':lowest.name==='Cardiovascular Health'?'cardiovascular':lowest.name==='Bone & Joint Health'?'bone-health':'sleep';
    if(metScore<60||hormScore<60||recScore<60||cardioScore<60||boneScore<60){
      var ctx='overall:'+overall+';metabolic:'+metScore+';hormones:'+hormScore+';sleep-recovery:'+recScore+';cardiovascular:'+cardioScore+';bone:'+boneScore;
      var href='/book?concern='+encodeURIComponent(specialistConcern)+'&source=assessment-quiz&result_context='+encodeURIComponent(ctx);
      document.getElementById('specialistCtaLink').setAttribute('href',href);
      document.getElementById('specialistCta').classList.add('active');
    }

    var links=[];
    if(metScore<70){
      links.push({href:'/guides/metabolic',label:'Guide',title:'Metabolic Health Guide'});
      links.push({href:'/insulin-resistance',label:'Article',title:'Insulin Resistance: Causes & Reversal'});
      links.push({href:'/tools/metabolic-score',label:'Tool',title:'Metabolic Score Calculator'});
    }
    if(hormScore<70){
      links.push({href:'/guides/hormones',label:'Guide',title:'Hormone Optimization Guide'});
      links.push({href:'/tools/hormone-checker',label:'Tool',title:'Hormone Symptom Checker'});
      links.push({href:'/low-testosterone',label:'Article',title:'Low Testosterone: Symptoms & Treatment'});
    }
    if(recScore<70){
      links.push({href:'/guides/recovery',label:'Guide',title:'Sleep & Recovery Guide'});
      links.push({href:'/tools/sleep-score',label:'Tool',title:'Sleep Recovery Score'});
      links.push({href:'/chronic-fatigue',label:'Article',title:'Chronic Fatigue: Root Causes'});
    }
    if(cardioScore<70){
      links.push({href:'/guides/heart-health',label:'Guide',title:'Heart Health Guide'});
      links.push({href:'/tools/heart-risk',label:'Tool',title:'Cardiovascular Risk Calculator'});
    }
    if(boneScore<70){
      links.push({href:'/guides/bone-health',label:'Guide',title:'Bone Health Guide'});
      links.push({href:'/osteoporosis',label:'Article',title:'Osteoporosis Prevention & Treatment'});
    }
    if(links.length===0){
      links.push({href:'/guides',label:'Guides',title:'All Health Guides'});
      links.push({href:'/tools',label:'Tools',title:'All Health Tools'});
    }

    var linksHtml='';
    links.forEach(function(l){
      linksHtml+='<a href="'+l.href+'" class="rec-link-card"><div class="rlc-label">'+l.label+'</div><div class="rlc-title">'+l.title+'</div></a>';
    });
    document.getElementById('recLinks').innerHTML=linksHtml;

    steps.forEach(function(s){s.classList.remove('active')});
    nav.style.display='none';
    document.querySelector('.progress-wrap').style.display='none';
    results.classList.add('active');
    document.querySelector('.quiz-header h1').textContent='Your Results';
    document.querySelector('.quiz-header p').textContent='Personalized analysis based on your answers';
    window.scrollTo({top:0,behavior:'smooth'});
  }
})();
</script>
{% endblock %}
