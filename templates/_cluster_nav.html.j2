{#
  Topic cluster navigation bar — renders horizontal hub links
  for the site's 4 primary health clusters.

  Usage:
    {% from "_cluster_nav.html.j2" import cluster_nav, cluster_nav_css %}
    {{ cluster_nav_css() }}
    {{ cluster_nav(current_cluster='metabolism') }}
#}

{% macro cluster_nav_css() %}
<style>
  .cluster-nav { display: flex; align-items: center; gap: 0; background: var(--h-gray-bg); border: 1px solid var(--h-gray-light); border-radius: 6px; overflow: hidden; margin: 24px 0; }
  .cluster-nav a { flex: 1; text-align: center; padding: 12px 16px; font-size: 13px; font-weight: 600; color: var(--h-gray-text); text-decoration: none; border-right: 1px solid var(--h-gray-light); transition: background 0.15s, color 0.15s; white-space: nowrap; }
  .cluster-nav a:last-child { border-right: 0; }
  .cluster-nav a:hover { background: var(--white); color: var(--h-teal); }
  .cluster-nav a.is-active { background: var(--white); color: var(--h-teal); box-shadow: inset 0 -2px 0 var(--h-teal); font-weight: 700; }
  @media (max-width: 640px) {
    .cluster-nav { flex-wrap: wrap; }
    .cluster-nav a { flex: 1 1 50%; border-bottom: 1px solid var(--h-gray-light); }
    .cluster-nav a:nth-child(2) { border-right: 0; }
    .cluster-nav a:nth-child(3), .cluster-nav a:nth-child(4) { border-bottom: 0; }
  }
</style>
{% endmacro %}

{% macro cluster_nav(current_cluster='') %}
{% set clusters = [
  {'slug': 'metabolism', 'label': 'Metabolic Health', 'href': '/metabolic-health'},
  {'slug': 'hormones', 'label': 'Hormones', 'href': '/hormone-optimization'},
  {'slug': 'recovery', 'label': 'Sleep & Recovery', 'href': '/sleep-recovery'},
  {'slug': 'testing', 'label': 'Testing & Biomarkers', 'href': '/lab-testing'},
] %}
<nav class="cluster-nav" aria-label="Health topics">
  {% for c in clusters %}
  <a href="{{ c.href }}"{% if current_cluster == c.slug %} class="is-active" aria-current="page"{% endif %}>{{ c.label }}</a>
  {% endfor %}
</nav>
{% endmacro %}
