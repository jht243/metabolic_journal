{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .hero {
    background: linear-gradient(135deg, var(--h-navy) 0%, var(--h-navy-dark) 100%);
    color: var(--white);
    padding: 80px 24px 72px;
    text-align: center;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4.5vw, 44px);
    line-height: 1.15;
    margin: 0 auto 18px;
    max-width: 720px;
  }
  .hero .subtitle {
    font-size: 18px;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
    margin: 0 auto 32px;
    line-height: 1.55;
  }

  .programs-section { padding: 64px 24px; background: var(--white); }
  .programs-section h2 { font-family: var(--font-serif); font-size: 28px; color: var(--h-navy); text-align: center; margin-bottom: 32px; }
  .program-card { text-align: center; padding: 32px 24px; }
  .program-card .icon { width: 56px; height: 56px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px; font-size: 24px; }
  .program-card .icon.metabolism { background: #dbeafe; color: #1e40af; }
  .program-card .icon.hormones { background: #fef3c7; color: #92400e; }
  .program-card .icon.recovery { background: #d1fae5; color: #065f46; }
  .program-card h3 { font-family: var(--font-serif); font-size: 18px; color: var(--h-navy); margin-bottom: 10px; }
  .program-card p { font-size: 14.5px; color: var(--h-gray-text); line-height: 1.55; }

  .how-section { padding: 64px 24px; background: var(--h-gray-bg); }
  .how-section h2 { font-family: var(--font-serif); font-size: 28px; color: var(--h-navy); text-align: center; margin-bottom: 40px; }
  .steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 32px; max-width: 960px; margin: 0 auto; }
  .step { text-align: center; }
  .step-num { width: 40px; height: 40px; border-radius: 50%; background: var(--h-teal); color: var(--white); font-weight: 700; font-size: 16px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .step h3 { font-family: var(--font-serif); font-size: 16px; color: var(--h-navy); margin-bottom: 8px; }
  .step p { font-size: 14px; color: var(--h-gray-text); line-height: 1.55; }

  .trust-bar { padding: 40px 24px; text-align: center; border-top: 1px solid var(--h-gray-light); border-bottom: 1px solid var(--h-gray-light); }
  .trust-items { display: flex; justify-content: center; gap: 48px; flex-wrap: wrap; max-width: 760px; margin: 0 auto; }
  .trust-item { font-size: 14px; color: var(--h-gray-text); font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-item svg { color: var(--h-teal); flex-shrink: 0; }

  .articles-section { padding: 64px 24px; }
  .articles-section h2 { font-family: var(--font-serif); font-size: 28px; color: var(--h-navy); text-align: center; margin-bottom: 32px; }
  .articles-section .see-all { text-align: center; margin-top: 24px; }

  .newsletter { padding: 56px 24px; background: var(--h-navy); color: var(--white); text-align: center; }
  .newsletter h2 { font-family: var(--font-serif); font-size: 24px; margin-bottom: 10px; }
  .newsletter p { color: rgba(255,255,255,0.7); margin-bottom: 24px; max-width: 480px; margin-left: auto; margin-right: auto; font-size: 15px; }
  .newsletter-form { display: flex; gap: 10px; max-width: 440px; margin: 0 auto; }
  .newsletter-form input[type="email"] { flex: 1; padding: 12px 16px; border: 0; border-radius: 5px; font-size: 15px; font-family: var(--font-sans); }
  .newsletter-form button { white-space: nowrap; }
  @media (max-width: 480px) { .newsletter-form { flex-direction: column; } }
</style>
{% endblock %}

{% block content %}
<section class="hero">
  <div class="container-wide">
    <h1>Understand Your Metabolism, Hormones, and&nbsp;Recovery</h1>
    <p class="subtitle">Free tools, research-backed guides, and expert-vetted product recommendations — so you can make informed decisions about your health, not guesses.</p>
    <a class="btn-primary" href="/assessment" style="font-size:17px; padding:14px 36px;">Take the Free Assessment →</a>
  </div>
</section>

<section class="programs-section">
  <div class="container-wide">
    <h2>What We Offer</h2>
    <div class="cr-card-grid">
      <a class="cr-card program-card" href="/tools">
        <span class="icon metabolism">⚡</span>
        <h3>Free Health Tools</h3>
        <p>Metabolic score calculators, hormone symptom checkers, sleep assessments, and insulin resistance risk tools — all free, instant, and backed by clinical research.</p>
        <span class="cr-card-action">Explore tools</span>
      </a>
      <a class="cr-card program-card" href="/metabolic-health">
        <span class="icon hormones">📊</span>
        <h3>Evidence-Based Guides</h3>
        <p>In-depth guides on insulin resistance, thyroid function, cortisol, sleep quality, and more — written with research citations, not wellness buzzwords.</p>
        <span class="cr-card-action">Browse guides</span>
      </a>
      <a class="cr-card program-card" href="/recommendations">
        <span class="icon recovery">🔬</span>
        <h3>Vetted Recommendations</h3>
        <p>Lab test kits, supplements, and health devices reviewed by our medical team — with honest assessments of what works, what doesn't, and who it's for.</p>
        <span class="cr-card-action">See our picks</span>
      </a>
    </div>
  </div>
</section>

<section class="programs-section">
  <div class="container-wide">
    <h2>Explore by Topic</h2>
    <div class="cr-card-grid">
      <a class="cr-card program-card" href="/metabolic-health">
        <span class="icon metabolism">📊</span>
        <h3>Metabolic Health</h3>
        <p>Insulin resistance, blood sugar, body composition, and metabolic syndrome.</p>
        <span class="cr-card-action">Explore metabolic health</span>
      </a>
      <a class="cr-card program-card" href="/hormone-optimization">
        <span class="icon hormones">🧬</span>
        <h3>Hormone Optimization</h3>
        <p>Testosterone, thyroid, cortisol, estrogen — testing and evidence-based protocols.</p>
        <span class="cr-card-action">Explore hormones</span>
      </a>
      <a class="cr-card program-card" href="/sleep-recovery">
        <span class="icon recovery">😴</span>
        <h3>Sleep &amp; Recovery</h3>
        <p>Chronic fatigue, poor sleep, low HRV, and impaired stress recovery.</p>
        <span class="cr-card-action">Explore recovery</span>
      </a>
      <a class="cr-card program-card" href="/lab-testing">
        <span class="icon testing">🔬</span>
        <h3>Lab Testing &amp; Biomarkers</h3>
        <p>Which tests to order, optimal ranges, and how to read your results.</p>
        <span class="cr-card-action">Explore lab testing</span>
      </a>
      <a class="cr-card program-card" href="/peptides">
        <span class="icon peptides">💊</span>
        <h3>Peptide Therapy</h3>
        <p>BPC-157, ipamorelin, sermorelin, GLP-1 — evidence-based peptide profiles.</p>
        <span class="cr-card-action">Explore peptides</span>
      </a>
    </div>
  </div>
</section>

<section class="how-section">
  <div class="container-wide">
    <h2>How It Works</h2>
    <div class="steps-grid">
      <div class="step">
        <span class="step-num">1</span>
        <h3>Assess</h3>
        <p>Use our free tools — symptom checkers, risk calculators, and health assessments — to get a clear picture of where you stand.</p>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <h3>Learn</h3>
        <p>Read our evidence-based guides to understand what your symptoms mean, which biomarkers matter, and what the research says.</p>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <h3>Act</h3>
        <p>See our vetted product recommendations — supplements, lab tests, devices — reviewed and rated by our medical advisory team.</p>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <h3>Connect</h3>
        <p>Need a specialist? We match you with a vetted doctor in metabolic health, endocrinology, or sleep medicine.</p>
      </div>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-items">
    <span class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
      62 research-backed guides and tools
    </span>
    <span class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
      Optimal functional ranges, not just "normal"
    </span>
    <span class="trust-item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
      Medical advisory board reviewed
    </span>
  </div>
</div>

{% if posts %}
<section class="articles-section">
  <div class="container-wide">
    <h2>Latest Articles</h2>
    <div class="cr-card-grid">
      {% for post in posts[:6] %}
      <a class="cr-card" href="{{ post.url }}">
        {% if post.cluster %}<span class="cr-card-eyebrow">{{ post.cluster }}</span>{% endif %}
        <h3 class="cr-card-headline">{{ post.title }}</h3>
        <p class="cr-card-tagline">{{ post.description }}</p>
        <span class="cr-card-action">Read article</span>
      </a>
      {% endfor %}
    </div>
    <div class="see-all">
      <a class="btn-secondary" href="/briefing">View All Articles</a>
    </div>
  </div>
</section>
{% endif %}

<section class="newsletter" id="newsletter">
  <h2>Get Smarter About Your Health</h2>
  <p>Weekly research breakdowns on metabolism, hormones, and recovery — evidence only, no hype.</p>
  <form class="newsletter-form" action="/subscribe" method="post">
    <input type="email" name="email" placeholder="Your email address" required aria-label="Email address">
    <button type="submit" class="btn-primary">Subscribe</button>
  </form>
  {% if request.args.get('subscribe') == 'success' %}
  <p style="color:#d1fae5; font-size:14px; margin:14px 0 0;">You're subscribed. Check your inbox for the next weekly breakdown.</p>
  {% elif request.args.get('subscribe') == 'invalid' %}
  <p style="color:#fecaca; font-size:14px; margin:14px 0 0;">Please enter a valid email address.</p>
  {% endif %}
</section>
{% endblock %}
